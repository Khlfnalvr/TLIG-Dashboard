<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Status Colors -->
    <SolidColorBrush x:Key="ColorNormalBrush"      Color="#FF25C685"/>
    <SolidColorBrush x:Key="ColorLowBrush"         Color="#FFFF8C00"/>
    <SolidColorBrush x:Key="ColorUndervoltBrush"   Color="#FFDC3545"/>
    <SolidColorBrush x:Key="ColorOvervoltBrush"    Color="#FF6F42C1"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FF0078D4"/>

    <!-- Card -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"        Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush"       Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="CornerRadius"      Value="8"/>
        <Setter Property="Padding"           Value="16"/>
    </Style>

    <!-- Section header (e.g. "PACK OVERVIEW") -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Opacity"          Value="0.55"/>
        <Setter Property="CharacterSpacing" Value="120"/>
        <Setter Property="Margin"           Value="0,8,0,0"/>
    </Style>

    <!-- Small uppercase label inside a card -->
    <Style x:Key="CardLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"         Value="10"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Opacity"          Value="0.55"/>
        <Setter Property="CharacterSpacing" Value="80"/>
    </Style>

    <!-- Large metric value -->
    <Style x:Key="CardValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin"     Value="0,4,0,0"/>
    </Style>

    <!-- Medium metric value -->
    <Style x:Key="MetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin"     Value="0,2,0,0"/>
    </Style>

    <!-- Form row label -->
    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Width"             Value="180"/>
    </Style>

</ResourceDictionary>
