<Window
    x:Class="TLIGDashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TLIGDashboard"
    xmlns:models="using:TLIGDashboard.Models"
    Title="TLIG Dashboard">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- playback bar -->
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded"
            RightTapped="TitleBar_RightTapped">

            <NavigationView.Resources>
                <!--
                    Compact top pane (32 px) matches the AppTitleBar height
                    exactly so the logo + nav labels sit visually centered
                    inside the title-bar strip.

                    The framework defaults position the selection underline a
                    few pixels above the item's bottom edge (via
                    NavigationViewItemBackgroundMargin +
                    TopNavigationViewItemSelectionIndicatorMargin), which is
                    what was causing the underline to overlap the text
                    descenders. We pin both to zero so the indicator sits
                    flush against the item bottom, freeing the full 30 px
                    above it for a vertically centered label.
                -->
                <x:Double x:Key="NavigationViewTopPaneHeight">32</x:Double>
                <x:Double x:Key="TopNavigationViewItemContentMinHeight">32</x:Double>
                <Thickness x:Key="NavigationViewItemButtonMargin">1,2</Thickness>
                <Thickness x:Key="TopNavigationViewItemContentOnlyContentPresenterMargin">6,0</Thickness>
                <Thickness x:Key="TopNavigationViewItemContentPresenterMargin">4,-1,6,-1</Thickness>
                <Thickness x:Key="NavigationViewItemBackgroundMargin">0,0,0,0</Thickness>
                <Thickness x:Key="TopNavigationViewItemSelectionIndicatorMargin">0,0,0,0</Thickness>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <Image x:Name="LogoImage"
                       Source="logo.png"
                       Height="22"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Stretch="Uniform"/>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <!--
                    Content is wrapped in an explicit TextBlock with
                    VerticalAlignment=Center because the default item template
                    hard-codes ContentPresenter.VerticalAlignment to Stretch,
                    leaving the label glued to the indicator. The top-nav
                    template does not honor item padding for label placement,
                    so the labels are translated up slightly.
                -->
                <NavigationViewItem x:Name="NavDashboard"  Tag="Dashboard"  MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="{x:Bind Lang.Nav_Dashboard, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavParameter"  Tag="Parameter"  MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="{x:Bind Lang.Nav_Parameter, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavLiveView"   Tag="LiveView"   MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="{x:Bind Lang.Nav_LiveView, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavLearningAnalytic" Tag="LearningAnalytic" MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="{x:Bind Lang.Nav_LearningAnalytic, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAI"         Tag="AI"         MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="{x:Bind Lang.Nav_AI, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <!--
                    Penilaian Mahasiswa — hanya untuk role Mahasiswa (client).
                    Disembunyikan saat login sebagai Dosen/Asisten oleh ApplyRoleNavVisibility().
                -->
                <NavigationViewItem x:Name="NavGradingStudent" Tag="GradingStudent" MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="Penilaian" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <!--
                    Manajemen Penilaian — hanya untuk role Dosen/Asisten.
                    Disembunyikan saat login sebagai Mahasiswa oleh ApplyRoleNavVisibility().
                -->
                <NavigationViewItem x:Name="NavGradingLecturer" Tag="GradingLecturer" MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="Penilaian" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <!--
                    Settings (broadcast + OPC UA + AI) — server flavor only. Declared
                    Visible (see NavUserManagement note) and hidden at load by
                    ApplyRoleNavVisibility().
                -->
                <NavigationViewItem x:Name="NavBroadcast" Tag="Broadcast" MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="{x:Bind Lang.Nav_Settings, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <!--
                    User Management — server flavor + Administrator only. Declared
                    Visible so the Top NavigationView realizes it into the bar (a
                    top-nav item that starts Collapsed is not reliably re-shown when
                    toggled Visible later); ApplyRoleNavVisibility() hides it at load
                    (behind the login overlay) and reveals it after an admin signs in.
                -->
                <NavigationViewItem x:Name="NavUserManagement" Tag="UserManagement" MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="{x:Bind Lang.Nav_UserManagement, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <!--
                    Log Aktivitas — hanya untuk Dosen/Asisten (staff).
                -->
                <NavigationViewItem x:Name="NavLogging" Tag="Logging" MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2" VerticalContentAlignment="Center">
                    <TextBlock Text="Log Aktivitas" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Padding="0"/>
        </NavigationView>

        <!--
            Invisible drag region — full width, IsHitTestVisible=False so NavView
            and the toggle below (in z-order) still receive pointer events.
        -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Height="32"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                IsHitTestVisible="False">
            <Border.ContextFlyout>
                <MenuFlyout x:Name="TitleBarCustomizeMenu" Placement="Bottom">
                    <MenuFlyoutSubItem x:Name="MenuView"
                                       FontSize="12"
                                       Text="{x:Bind Lang.Ui_Menu_View, Mode=OneWay}">
                        <ToggleMenuFlyoutItem x:Name="ViewNavDashboard"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_Dashboard, Mode=OneWay}"
                                              Tag="Dashboard"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavParameter"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_Parameter, Mode=OneWay}"
                                              Tag="Parameter"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavLiveView"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_LiveView, Mode=OneWay}"
                                              Tag="LiveView"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavLearningAnalytic"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_LearningAnalytic, Mode=OneWay}"
                                              Tag="LearningAnalytic"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavAI"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_AI, Mode=OneWay}"
                                              Tag="AI"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                    </MenuFlyoutSubItem>

                    <MenuFlyoutSubItem x:Name="MenuZoom"
                                       FontSize="12"
                                       Text="{x:Bind Lang.Ui_Menu_Zoom, Mode=OneWay}">
                        <MenuFlyoutItem x:Name="ZoomActualSize"
                                        FontSize="12"
                                        Text="{x:Bind Lang.Ui_Menu_ActualSize, Mode=OneWay}"
                                        KeyboardAcceleratorTextOverride="Ctrl+0"
                                        Click="ZoomActualSize_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Number0"/>
                                <KeyboardAccelerator Modifiers="Control" Key="NumberPad0"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="ZoomIn"
                                        FontSize="12"
                                        Text="{x:Bind Lang.Ui_Menu_ZoomIn, Mode=OneWay}"
                                        KeyboardAcceleratorTextOverride="Ctrl++"
                                        Click="ZoomIn_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Add"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="ZoomOut"
                                        FontSize="12"
                                        Text="{x:Bind Lang.Ui_Menu_ZoomOut, Mode=OneWay}"
                                        KeyboardAcceleratorTextOverride="Ctrl+-"
                                        Click="ZoomOut_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Subtract"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem x:Name="MenuAbout"
                                       FontSize="12"
                                       Text="{x:Bind Lang.Ui_Menu_About, Mode=OneWay}">
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutProductText, Mode=OneWay}"/>
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutVersionText, Mode=OneWay}"/>
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutLicenseText, Mode=OneWay}"/>
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutCopyrightText, Mode=OneWay}"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem x:Name="MenuDeveloper"
                                       FontSize="12"
                                       Text="{x:Bind Lang.Ui_Menu_Developer, Mode=OneWay}">
                        <MenuFlyoutItem x:Name="MenuGithub"
                                        FontSize="12"
                                        Text="Github"
                                        Click="MenuGithub_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xE8A7;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuOpenLogFolder"
                                        FontSize="12"
                                        Text="{x:Bind Lang.Ui_Menu_OpenLogFolder, Mode=OneWay}"
                                        Click="MenuOpenLogFolder_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xE838;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuOpenSettings"
                                        FontSize="12"
                                        Text="{x:Bind Lang.Ui_Menu_OpenSettings, Mode=OneWay}"
                                        Click="MenuOpenSettings_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xE7C3;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuReportBug"
                                        FontSize="12"
                                        Text="{x:Bind Lang.Ui_Menu_ReportBug, Mode=OneWay}"
                                        Click="MenuReportBug_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xEBE8;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:Name="MenuEarlyAccess"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Ui_Menu_EarlyAccess, Mode=OneWay}"
                                              Click="MenuEarlyAccess_Click">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xECAD;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuTour"
                                    FontSize="12"
                                    Text="{x:Bind Lang.Ui_Menu_Tour, Mode=OneWay}"
                                    Click="MenuTour_Click"/>
                    <MenuFlyoutItem x:Name="MenuCheckUpdate"
                                    FontSize="12"
                                    Text="{x:Bind Lang.Ui_Menu_CheckUpdate, Mode=OneWay}"
                                    Click="MenuCheckUpdate_Click"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuRefreshApp"
                                    FontSize="12"
                                    Text="{x:Bind Lang.Ui_Menu_RefreshApp, Mode=OneWay}"
                                    KeyboardAcceleratorTextOverride="Ctrl+R"
                                    Click="RefreshApp_Click">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="R"/>
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Border.ContextFlyout>
        </Border>

        <!--
            Caption-style icon buttons — language picker + theme toggle, sitting
            immediately left of the minimize/maximize/close buttons (mirrors the
            Visual Studio Installer pattern). The code-behind shrinks
            AppTitleBar's right margin so this whole area sits outside the drag
            region.
        -->
        <Border x:Name="ThemeToggleArea"
                Grid.Row="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
                <!-- Update-available notification button — hidden until a newer release is found -->
                <Button x:Name="UpdateNotifyBtn"
                        Style="{StaticResource CaptionButtonStyle}"
                        Visibility="Collapsed"
                        Click="UpdateNotifyBtn_Click">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="15"
                              Glyph="&#xE777;"
                              Foreground="#F79022"/>
                </Button>

                <!-- Account button — shows logged-in user and logout option -->
                <Button x:Name="AccountBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14"
                              Glyph="&#xE77B;"/>
                    <Button.Flyout>
                        <Flyout x:Name="AccountFlyout"
                                Placement="Bottom"
                                Opening="AccountFlyout_Opening">
                            <StackPanel Width="220" Spacing="10">
                                <!-- User info -->
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{x:Bind Lang.Account_LoggedInAs, Mode=OneWay}"
                                               FontSize="11" Opacity="0.6"/>
                                    <TextBlock x:Name="AccountUsernameText"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="AccountEmailText"
                                               FontSize="11" Opacity="0.5"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5"/>
                                <!-- Edit profile -->
                                <Button x:Name="EditProfileBtn"
                                        HorizontalAlignment="Stretch"
                                        FontSize="12"
                                        Click="EditProfileBtn_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                  Glyph="&#xE70F;" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Lang.Profile_EditBtn, Mode=OneWay}"/>
                                    </StackPanel>
                                </Button>
                                <!-- Logout -->
                                <Button x:Name="LogoutBtn"
                                        HorizontalAlignment="Stretch"
                                        FontSize="12"
                                        Click="LogoutBtn_Click"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- OPC UA connection button — opens a flyout with endpoint URL,
                     security mode, and credentials. The status dot reflects live
                     connection state (green = connected, grey = disconnected). -->
                <Button x:Name="OpcUaBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <Grid>
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="14"
                                  Glyph="&#xE968;"/>
                        <Ellipse x:Name="OpcStatusDot"
                                 Width="6" Height="6"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,10,6"/>
                    </Grid>
                    <Button.Flyout>
                        <Flyout x:Name="OpcUaFlyout"
                                Placement="Bottom"
                                Opened="OpcUaFlyout_Opened">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Padding"         Value="12,0,12,12"/>
                                    <Setter Property="CornerRadius"    Value="{ThemeResource OverlayCornerRadius}"/>
                                    <Setter Property="BorderBrush"     Value="{ThemeResource SurfaceStrokeColorFlyoutBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Style>
                            </Flyout.FlyoutPresenterStyle>

                            <StackPanel Width="300" Spacing="8" Padding="0,4,0,0">

                                <!-- ── Tab selector ──────────────────────── -->
                                <SelectorBar x:Name="ConnAiTabs"
                                             SelectionChanged="ConnAiTabs_SelectionChanged">
                                    <SelectorBarItem x:Name="TabOpcUa"
                                                     FontSize="12" Padding="12,4,12,4"
                                                     Text="{x:Bind Lang.Ui_OpcUaConnection, Mode=OneWay}"/>
                                    <SelectorBarItem x:Name="TabAiApi"
                                                     FontSize="12" Padding="12,4,12,4"
                                                     Text="{x:Bind Lang.Ai_Settings, Mode=OneWay}"/>
                                    <SelectorBarItem x:Name="TabShare"
                                                     FontSize="12" Padding="12,4,12,4"/>
                                </SelectorBar>

                                <!-- ══ OPC PANEL ══════════════════════════════ -->
                                <StackPanel x:Name="PanelOpcUa" Spacing="10">

                                    <!-- Protocol selector -->
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{x:Bind Lang.Ui_OpcProtocol, Mode=OneWay}"
                                                   FontSize="11" Opacity="0.65"/>
                                        <ComboBox x:Name="OpcProtocolCombo"
                                                  FontSize="12"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="OpcProtocolCombo_SelectionChanged">
                                            <ComboBoxItem x:Name="OpcProtoUa" Tag="UA"  Content="OPC UA"/>
                                            <ComboBoxItem x:Name="OpcProtoDa" Tag="DA"  Content="OPC DA (Classic)"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- ── OPC UA fields ── -->
                                    <StackPanel x:Name="OpcUaFields" Spacing="10">

                                        <!-- Endpoint URL -->
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{x:Bind Lang.Ui_OpcUaEndpoint, Mode=OneWay}"
                                                       FontSize="11" Opacity="0.65"/>
                                            <TextBox x:Name="OpcEndpointBox"
                                                     FontSize="12"
                                                     PlaceholderText="opc.tcp://host:4840"/>
                                        </StackPanel>

                                        <!-- Security Mode -->
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{x:Bind Lang.Ui_OpcUaSecurity, Mode=OneWay}"
                                                       FontSize="11" Opacity="0.65"/>
                                            <ComboBox x:Name="OpcSecurityCombo"
                                                      FontSize="12"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OpcSecurityCombo_SelectionChanged">
                                                <ComboBoxItem x:Name="OpcSecNone"    Tag="None"/>
                                                <ComboBoxItem x:Name="OpcSecSign"    Tag="Sign"/>
                                                <ComboBoxItem x:Name="OpcSecSignEnc" Tag="SignAndEncrypt"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Authentication -->
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{x:Bind Lang.Ui_OpcUaAuth, Mode=OneWay}"
                                                       FontSize="11" Opacity="0.65"/>
                                            <ComboBox x:Name="OpcAuthCombo"
                                                      FontSize="12"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OpcAuthCombo_SelectionChanged">
                                                <ComboBoxItem x:Name="OpcAuthAnon" Tag="Anonymous"/>
                                                <ComboBoxItem x:Name="OpcAuthUser" Tag="Username"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Username / Password -->
                                        <StackPanel x:Name="OpcCredPanel"
                                                    Spacing="6"
                                                    Visibility="Collapsed">
                                            <TextBox x:Name="OpcUsernameBox"
                                                     FontSize="12"
                                                     PlaceholderText="{x:Bind Lang.Ui_OpcUaUsername, Mode=OneWay}"/>
                                            <PasswordBox x:Name="OpcPasswordBox"
                                                         FontSize="12"
                                                         PlaceholderText="{x:Bind Lang.Ui_OpcUaPassword, Mode=OneWay}"/>
                                        </StackPanel>

                                        <!-- Open certificate folder -->
                                        <HyperlinkButton x:Name="OpcCertFolderBtn"
                                                         FontSize="11" Padding="0,2,0,2"
                                                         Content="{x:Bind Lang.Ui_OpcUaOpenCertFolder, Mode=OneWay}"
                                                         Click="OpcCertFolderBtn_Click"/>

                                    </StackPanel>

                                    <!-- ── OPC DA fields ── -->
                                    <StackPanel x:Name="OpcDaFields" Spacing="10" Visibility="Collapsed">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{x:Bind Lang.Ui_OpcDaProgId, Mode=OneWay}"
                                                       FontSize="11" Opacity="0.65"/>
                                            <TextBox x:Name="OpcDaProgIdBox"
                                                     FontSize="12"
                                                     PlaceholderText="National Instruments.NIOPCServers.V5"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Connect / Disconnect -->
                                    <Button x:Name="OpcConnectBtn"
                                            FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Click="OpcConnectBtn_Click"
                                            Content="{x:Bind Lang.Ctrl_Connect, Mode=OneWay}"/>

                                    <!-- Status -->
                                    <TextBlock x:Name="OpcStatusText"
                                               FontSize="11" Opacity="0.7"
                                               TextWrapping="Wrap"
                                               Text="{x:Bind Lang.Ctrl_NotConnected, Mode=OneWay}"/>

                                </StackPanel>

                                <!-- ══ AI API PANEL ══════════════════════════ -->
                                <StackPanel x:Name="PanelAiApi"
                                            Spacing="10"
                                            Visibility="Collapsed">

                                    <!-- Multi-provider config (DeepSeek / OpenAI / Anthropic) -->
                                    <TextBlock Text="{x:Bind Lang.Ai_ProvidersHint, Mode=OneWay}"
                                               FontSize="11" Opacity="0.65"
                                               TextWrapping="Wrap"/>

                                    <Button x:Name="AiConfigBtn"
                                            FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Click="AiConfigBtn_Click"
                                            Content="{x:Bind Lang.Ai_ConfigTitle, Mode=OneWay}"/>

                                    <!-- AI status indicator -->
                                    <TextBlock x:Name="AiStatusText"
                                               FontSize="11" Opacity="0.7"
                                               TextWrapping="Wrap"/>

                                </StackPanel>

                                <!-- ══ CONNECT PANEL (client flavor) ════════════ -->
                                <!--
                                    Connecting now happens through the credential
                                    login popup. This panel reflects the current
                                    session and lets the user reconnect, disconnect,
                                    or sign in to a different server.
                                -->
                                <StackPanel x:Name="PanelConnect"
                                            Spacing="10"
                                            Visibility="Collapsed">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{x:Bind Lang.Share_ServerAccount, Mode=OneWay}"
                                                   FontSize="11" Opacity="0.65"/>
                                        <TextBlock x:Name="ConnectServerInfoText"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Button x:Name="ConnectServerBtn"
                                            FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Click="ConnectServerBtn_Click"/>

                                    <Button x:Name="SwitchServerBtn"
                                            FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            Click="SwitchServerBtn_Click"
                                            Content="{x:Bind Lang.Share_LoginAgain, Mode=OneWay}"/>

                                    <TextBlock x:Name="ClientStatusText"
                                               FontSize="11" Opacity="0.7"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <Button x:Name="LangBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14"
                              Glyph="&#xE12B;"/>
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <RadioMenuFlyoutItem x:Name="LangItemId" FontSize="12" Text="Indonesia" Tag="id" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemEn" FontSize="12" Text="English"   Tag="en" GroupName="LangGroup" Click="LangItem_Click"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="ThemeBtn"
                        Style="{StaticResource CaptionButtonStyle}"
                        Click="ThemeBtn_Click">
                    <FontIcon x:Name="ThemeIcon"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14"
                              Glyph="&#xE706;"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Standard WinUI InfoBar: inline, themed by Severity, and not docked as a bottom status bar. -->
        <InfoBar x:Name="StatusInfoBar"
                 Grid.Row="0"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 MinWidth="320"
                 MaxWidth="600"
                 Margin="16,44,16,0"
                 IsOpen="{x:Bind ViewModel.StatusInfoBarIsOpen, Mode=OneWay}"
                 IsClosable="True"
                 Severity="Warning"
                 Title="{x:Bind ViewModel.DataSourceText, Mode=OneWay}"
                 Message="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}">
            <InfoBar.Resources>
                <!-- Override InfoBar internal text styles to match the compact UI -->
                <Style x:Key="InfoBarTitleStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
                <Style x:Key="InfoBarBodyStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
            </InfoBar.Resources>
        </InfoBar>

        <!--  Update dialog overlay  -->
        <Grid x:Name="UpdateOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Canvas.ZIndex="19">
            <Grid.Background>
                <AcrylicBrush TintColor="Black"
                              TintOpacity="0.55"
                              TintLuminosityOpacity="0.0"
                              AlwaysUseFallback="True"
                              FallbackColor="#8D000000"/>
            </Grid.Background>
            <Border x:Name="UpdateDialogCard"
                    Width="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="UpdateDialogTitle"
                               Grid.Row="0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="28,24,28,0"/>
                    <ContentControl x:Name="UpdateContentHost"
                                    Grid.Row="1"
                                    Margin="28,16,28,0"
                                    HorizontalContentAlignment="Stretch"
                                    HorizontalAlignment="Stretch"/>
                    <Border Grid.Row="2"
                            Padding="28,16"
                            Margin="0,16,0,0"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="UpdatePrimaryButton"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Visibility="Collapsed"
                                    Click="UpdatePrimary_Click"/>
                            <Button x:Name="UpdateCloseButton"
                                    Grid.Column="1"
                                    MinWidth="90"
                                    Click="UpdateClose_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="TourOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Canvas.ZIndex="20">
            <Grid.Background>
                <AcrylicBrush TintColor="Black"
                              TintOpacity="0.55"
                              TintLuminosityOpacity="0.0"
                              AlwaysUseFallback="True"
                              FallbackColor="#8D000000"/>
            </Grid.Background>
            <Border x:Name="TourDialogCard"
                    Width="620"
                    MaxHeight="760"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="30,28,30,12"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <Image x:Name="TourLogoImage"
                               Height="30"
                               VerticalAlignment="Center"
                               Stretch="Uniform"/>
                        <TextBlock x:Name="TourDialogTitle"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ContentControl x:Name="TourContentHost"
                                    Grid.Row="1"
                                    Margin="30,0,30,0"
                                    HorizontalContentAlignment="Center"/>

                    <Border Grid.Row="2"
                            Padding="30,18"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="TourOpenControlPanelButton"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Click="TourOpenControlPanel_Click"/>
                            <Button x:Name="TourCloseButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Click="TourClose_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- ── Login overlay (shown on startup, ZIndex above all others) ── -->
        <Grid x:Name="LoginOverlay"
              Grid.RowSpan="3"
              Canvas.ZIndex="30">
            <Grid.Background>
                <AcrylicBrush TintColor="Black"
                              TintOpacity="0.65"
                              TintLuminosityOpacity="0.0"
                              AlwaysUseFallback="True"
                              FallbackColor="#A6000000"/>
            </Grid.Background>
            <Border x:Name="LoginDialogCard"
                    Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>

                    <!-- Close button — floats over the top-right corner -->
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="28" Height="28"
                            Padding="0"
                            Margin="0,8,8,0"
                            Style="{StaticResource CaptionButtonStyle}"
                            Canvas.ZIndex="1"
                            Click="LoginClose_Click">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="11"
                                  Glyph="&#xE711;"/>
                    </Button>

                    <StackPanel>

                        <!-- Header: logo + title -->
                        <StackPanel Padding="28,24,28,4" Spacing="6">
                            <Image x:Name="LoginLogoImage"
                                   Height="22"
                                   HorizontalAlignment="Left"
                                   Stretch="Uniform"/>
                            <TextBlock Text="{x:Bind Lang.Login_Title, Mode=OneWay}"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="TLIG Dashboard"
                                       FontSize="12"
                                       Opacity="0.55"/>
                        </StackPanel>

                        <!-- Form fields -->
                        <StackPanel Padding="28,16,28,0" Spacing="14">
                            <!-- Server address — client flavor only (toggled in code-behind) -->
                            <StackPanel x:Name="LoginServerPanel" Spacing="6" Visibility="Collapsed">
                                <TextBlock Text="{x:Bind Lang.Login_ServerAddress, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="LoginServerBox"
                                         FontSize="12"
                                         PlaceholderText="{x:Bind Lang.Login_ServerAddressHint, Mode=OneWay}"
                                         KeyDown="LoginServer_KeyDown"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Lang.Login_Username, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="LoginUsernameBox"
                                         FontSize="12"
                                         PlaceholderText="{x:Bind Lang.Login_UsernameHint, Mode=OneWay}"
                                         KeyDown="LoginUsername_KeyDown"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Lang.Login_Password, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="LoginPasswordBox"
                                             FontSize="12"
                                             PlaceholderText="{x:Bind Lang.Login_PasswordHint, Mode=OneWay}"
                                             KeyDown="LoginPassword_KeyDown"/>
                            </StackPanel>
                            <TextBlock x:Name="LoginErrorText"
                                       FontSize="11"
                                       Foreground="#FFDC3545"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="LoginInfoText"
                                       FontSize="11"
                                       Foreground="#FF2E7D32"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Footer: submit button -->
                        <Border Padding="28,16"
                                Margin="0,16,0,0"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <StackPanel x:Name="LoginBusyPanel"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            Visibility="Collapsed">
                                    <ProgressRing Width="16" Height="16" IsActive="True"/>
                                    <TextBlock Text="{x:Bind Lang.Login_Connecting, Mode=OneWay}"
                                               FontSize="12" Opacity="0.75"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="LoginSubmitBtn"
                                        HorizontalAlignment="Stretch"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        FontSize="12"
                                        Content="{x:Bind Lang.Login_Submit, Mode=OneWay}"
                                        Click="LoginSubmit_Click"/>
                                <!-- Self-registration entry point — client flavor only (toggled in code-behind) -->
                                <HyperlinkButton x:Name="LoginToSignupLink"
                                                 HorizontalAlignment="Center"
                                                 Padding="2"
                                                 FontSize="12"
                                                 Visibility="Collapsed"
                                                 Content="{x:Bind Lang.Signup_CreateAccountLink, Mode=OneWay}"
                                                 Click="LoginToSignup_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Signup card — client self-registration (@its.ac.id). Swapped with
                 the login card in code-behind; hidden by default. ── -->
            <Border x:Name="SignupDialogCard"
                    Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <Grid>

                    <!-- Close button — floats over the top-right corner -->
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="28" Height="28"
                            Padding="0"
                            Margin="0,8,8,0"
                            Style="{StaticResource CaptionButtonStyle}"
                            Canvas.ZIndex="1"
                            Click="LoginClose_Click">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="11"
                                  Glyph="&#xE711;"/>
                    </Button>

                    <StackPanel>

                        <!-- Header: title + subtitle -->
                        <StackPanel Padding="28,24,28,4" Spacing="6">
                            <TextBlock Text="{x:Bind Lang.Signup_Title, Mode=OneWay}"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Lang.Signup_Subtitle, Mode=OneWay}"
                                       FontSize="12"
                                       Opacity="0.55"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Form fields -->
                        <StackPanel Padding="28,16,28,0" Spacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Lang.Login_ServerAddress, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="SignupServerBox"
                                         FontSize="12"
                                         PlaceholderText="{x:Bind Lang.Login_ServerAddressHint, Mode=OneWay}"
                                         KeyDown="SignupServer_KeyDown"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Lang.Signup_Email, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="SignupEmailBox"
                                         FontSize="12"
                                         InputScope="EmailNameOrAddress"
                                         PlaceholderText="{x:Bind Lang.Signup_EmailHint, Mode=OneWay}"
                                         KeyDown="SignupEmail_KeyDown"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Lang.Login_Password, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="SignupPasswordBox"
                                             FontSize="12"
                                             PlaceholderText="{x:Bind Lang.Login_PasswordHint, Mode=OneWay}"
                                             KeyDown="SignupPassword_KeyDown"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Lang.Signup_ConfirmPassword, Mode=OneWay}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="SignupConfirmBox"
                                             FontSize="12"
                                             PlaceholderText="{x:Bind Lang.Signup_ConfirmPasswordHint, Mode=OneWay}"
                                             KeyDown="SignupConfirm_KeyDown"/>
                            </StackPanel>
                            <TextBlock x:Name="SignupErrorText"
                                       FontSize="11"
                                       Foreground="#FFDC3545"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Footer: register button + back link -->
                        <Border Padding="28,16"
                                Margin="0,16,0,0"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <StackPanel x:Name="SignupBusyPanel"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            Visibility="Collapsed">
                                    <ProgressRing Width="16" Height="16" IsActive="True"/>
                                    <TextBlock Text="{x:Bind Lang.Login_Connecting, Mode=OneWay}"
                                               FontSize="12" Opacity="0.75"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="SignupSubmitBtn"
                                        HorizontalAlignment="Stretch"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        FontSize="12"
                                        Content="{x:Bind Lang.Signup_Submit, Mode=OneWay}"
                                        Click="SignupSubmit_Click"/>
                                <HyperlinkButton x:Name="SignupToLoginLink"
                                                 HorizontalAlignment="Center"
                                                 Padding="2"
                                                 FontSize="12"
                                                 Content="{x:Bind Lang.Signup_BackToLogin, Mode=OneWay}"
                                                 Click="SignupToLogin_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
