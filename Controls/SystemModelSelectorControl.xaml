<UserControl
    x:Class="TLIGDashboard.Controls.SystemModelSelectorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Dark card base -->
        <Style x:Key="SmsCardBase" TargetType="Border">
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background"      Value="#1E1E2E"/>
        </Style>

        <!-- Small label -->
        <Style x:Key="SmsMuted" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity"  Value="0.55"/>
        </Style>

    </UserControl.Resources>

    <!-- Flyout anchor button -->
    <Button x:Name="AnchorBtn"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            Click="AnchorBtn_Click">

        <!-- Collapsed view: shows current selection -->
        <Border x:Name="CollapsedView"
                Background="#1E1E2E"
                BorderBrush="#7c3aed"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="10,4"
                Height="28"
                VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="CollapsedName"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#E0E0F0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="CollapsedUnit"
                           FontSize="10"
                           Foreground="#7c3aed"
                           Opacity="0.9"
                           VerticalAlignment="Center"/>
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          Glyph="&#xE70D;"
                          FontSize="9"
                          Foreground="#7c3aed"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Button.Flyout>
            <Flyout x:Name="SelectorFlyout"
                    Placement="Bottom"
                    FlyoutPresenterStyle="{StaticResource SmsFlyoutStyle}">
                <StackPanel Spacing="8" Padding="4">

                    <!-- Header -->
                    <TextBlock Text="PILIH SISTEM PROSES"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#7c3aed"
                               Opacity="0.85"
                               Margin="2,0,0,4"/>

                    <!-- Flow card -->
                    <Border x:Name="CardFlow"
                            Style="{StaticResource SmsCardBase}"
                            BorderBrush="#2D2D3E"
                            PointerPressed="CardFlow_Pressed"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon chip -->
                            <Border Grid.Column="0"
                                    Width="36" Height="36"
                                    CornerRadius="8"
                                    Background="#1A2A3A">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xF4E0;"
                                          FontSize="18"
                                          Foreground="#38BDF8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <!-- Text -->
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Flow"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#E0E0F0"/>
                                <TextBlock Text="Control laju aliran fluida dalam pipa"
                                           Style="{StaticResource SmsMuted}"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                    <Border Background="#1A2A3A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="K = 1.2" FontSize="10" Foreground="#38BDF8"/>
                                    </Border>
                                    <Border Background="#1A2A3A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="τ = 5 s" FontSize="10" Foreground="#38BDF8"/>
                                    </Border>
                                    <Border Background="#1A2A3A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="L/min" FontSize="10" Foreground="#38BDF8"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Check mark -->
                            <FontIcon x:Name="CheckFlow"
                                      Grid.Column="2"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      Glyph="&#xE73E;"
                                      FontSize="14"
                                      Foreground="#7c3aed"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Level card -->
                    <Border x:Name="CardLevel"
                            Style="{StaticResource SmsCardBase}"
                            BorderBrush="#2D2D3E"
                            PointerPressed="CardLevel_Pressed"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="36" Height="36"
                                    CornerRadius="8"
                                    Background="#1A2D1A">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xE9CA;"
                                          FontSize="18"
                                          Foreground="#34D399"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Level"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#E0E0F0"/>
                                <TextBlock Text="Kontrol ketinggian cairan dalam tangki"
                                           Style="{StaticResource SmsMuted}"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                    <Border Background="#1A2D1A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="K = 2.0" FontSize="10" Foreground="#34D399"/>
                                    </Border>
                                    <Border Background="#1A2D1A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="τ = 10 s" FontSize="10" Foreground="#34D399"/>
                                    </Border>
                                    <Border Background="#1A2D1A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="cm" FontSize="10" Foreground="#34D399"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <FontIcon x:Name="CheckLevel"
                                      Grid.Column="2"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      Glyph="&#xE73E;"
                                      FontSize="14"
                                      Foreground="#7c3aed"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Temperature card -->
                    <Border x:Name="CardTemp"
                            Style="{StaticResource SmsCardBase}"
                            BorderBrush="#2D2D3E"
                            PointerPressed="CardTemp_Pressed"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="36" Height="36"
                                    CornerRadius="8"
                                    Background="#2D1A1A">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Glyph="&#xE9CA;"
                                          FontSize="18"
                                          Foreground="#F87171"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Temperature"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#E0E0F0"/>
                                <TextBlock Text="Regulasi suhu pada heat exchanger"
                                           Style="{StaticResource SmsMuted}"
                                           TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                    <Border Background="#2D1A1A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="K = 0.8" FontSize="10" Foreground="#F87171"/>
                                    </Border>
                                    <Border Background="#2D1A1A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="τ = 30 s" FontSize="10" Foreground="#F87171"/>
                                    </Border>
                                    <Border Background="#2D1A1A" CornerRadius="4" Padding="5,2">
                                        <TextBlock Text="°C" FontSize="10" Foreground="#F87171"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <FontIcon x:Name="CheckTemp"
                                      Grid.Column="2"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      Glyph="&#xE73E;"
                                      FontSize="14"
                                      Foreground="#7c3aed"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </Flyout>
        </Button.Flyout>
    </Button>

</UserControl>
