<UserControl
    x:Class="TLIGDashboard.Controls.HmiShareView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="HeaderText"
                       Grid.Column="0"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.82"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="SourceSelector"
                      Grid.Column="1"
                      MinWidth="128"
                      MaxWidth="220"
                      Height="28"
                      FontSize="11"
                      SelectionChanged="SourceSelector_SelectionChanged"/>

            <Button x:Name="RefreshSourcesButton"
                    Grid.Column="2"
                    Height="28"
                    MinWidth="68"
                    Padding="10,0"
                    FontSize="11"
                    Click="RefreshSourcesButton_Click"/>

            <Button x:Name="StopShareButton"
                    Grid.Column="3"
                    Height="28"
                    MinWidth="54"
                    Padding="10,0"
                    FontSize="11"
                    Visibility="Collapsed"
                    Click="StopShareButton_Click"/>
        </Grid>

        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Image x:Name="CaptureImage"
                       Stretch="Uniform"
                       Visibility="Collapsed"/>

                <StackPanel x:Name="PlaceholderPanel"
                            Spacing="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="18">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              Glyph="&#xE7F4;"
                              FontSize="28"
                              Opacity="0.62"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PlaceholderText"
                               FontSize="11"
                               Opacity="0.62"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="280"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
