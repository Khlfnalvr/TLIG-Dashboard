<UserControl
    x:Class="TLIGDashboard.Controls.LearningAnalyticView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes">

    <UserControl.Resources>

        <!-- Accent palette — fixed colours, readable on both light & dark themes -->
        <SolidColorBrush x:Key="AccentGreen"  Color="#FF10B981"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#FF3B82F6"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#FF8B5CF6"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFF59E0B"/>

        <!-- Soft tints for icon chips / pills (~15% alpha) -->
        <SolidColorBrush x:Key="TintGreen"  Color="#2610B981"/>
        <SolidColorBrush x:Key="TintBlue"   Color="#263B82F6"/>
        <SolidColorBrush x:Key="TintPurple" Color="#268B5CF6"/>
        <SolidColorBrush x:Key="TintOrange" Color="#26F59E0B"/>

        <LinearGradientBrush x:Key="GaugeValueBrush" StartPoint="0,1" EndPoint="1,0">
            <GradientStop Color="#FF34D399" Offset="0"/>
            <GradientStop Color="#FF059669" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="LDCard" TargetType="Border">
            <Setter Property="Background"      Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="16"/>
        </Style>

        <Style x:Key="LDCardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LDMuted" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity"  Value="0.6"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20,16,20,20">
        <StackPanel Spacing="14" MaxWidth="1180" HorizontalAlignment="Left">

            <!-- Page header -->
            <StackPanel Spacing="2" Margin="2,0,0,2">
                <TextBlock Text="{x:Bind Lang.Nav_LearningAnalytic, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind Lang.LearnDash_Subtitle, Mode=OneWay}"
                           Style="{StaticResource LDMuted}"/>
            </StackPanel>

            <!-- ═══ TOP BAND: overall performance (from tasks) · task summary ═══ -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <!-- Overall performance = % of tasks completed -->
                <Border Grid.Column="0" Style="{StaticResource LDCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.LearnDash_OverallPerf, Mode=OneWay}"
                                   Style="{StaticResource LDCardTitle}"/>
                        <TextBlock Text="{x:Bind Lang.LearnDash_CompletionRate, Mode=OneWay}"
                                   Style="{StaticResource LDMuted}"/>
                        <Grid Width="164" Height="104" Margin="0,8,0,0" HorizontalAlignment="Center">
                            <Canvas Width="164" Height="100">
                                <shapes:Path x:Name="GaugeTrack"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}"
                                             StrokeThickness="14"
                                             StrokeStartLineCap="Round"
                                             StrokeEndLineCap="Round"/>
                                <shapes:Path x:Name="GaugeValue"
                                             Stroke="{StaticResource GaugeValueBrush}"
                                             StrokeThickness="14"
                                             StrokeStartLineCap="Round"
                                             StrokeEndLineCap="Round"/>
                            </Canvas>
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock x:Name="OverallPercentText" Text="0%" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="OverallSubText" Text="" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Task summary: total / completed / remaining -->
                <Border Grid.Column="1" Style="{StaticResource LDCard}">
                    <StackPanel Spacing="14" VerticalAlignment="Center">

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource TintBlue}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE9D5;" FontSize="18" Foreground="{StaticResource AccentBlue}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Lang.LearnDash_TotalTasks, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" x:Name="TotalTasksText" Text="0" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource TintGreen}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE930;" FontSize="18" Foreground="{StaticResource AccentGreen}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Lang.LearnDash_Completed, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" x:Name="DoneTasksText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource TintOrange}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE823;" FontSize="18" Foreground="{StaticResource AccentOrange}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Lang.LearnDash_Remaining, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" x:Name="RemainingTasksText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentOrange}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ TASKS LIST ═══ -->
            <Border Style="{StaticResource LDCard}">
                <StackPanel Spacing="10">
                    <!-- Title row + staff-only Add button -->
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Lang.LearnDash_TasksTitle, Mode=OneWay}" Style="{StaticResource LDCardTitle}"/>
                            <TextBlock x:Name="TaskCountText" Text="(0)" FontSize="15" FontWeight="SemiBold" Opacity="0.5" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="AddTaskBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                                FontSize="12" Padding="11,4" Visibility="Collapsed" Click="AddTask_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11"/>
                                <TextBlock Text="{x:Bind Lang.LearnDash_AddTask, Mode=OneWay}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock x:Name="EmptyText" Text="{x:Bind Lang.LearnDash_NoTasks, Mode=OneWay}"
                               Style="{StaticResource LDMuted}" Visibility="Collapsed" Margin="2,6,0,6"/>

                    <!-- Clickable task rows → detail page -->
                    <ItemsControl x:Name="TasksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="TaskRow_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0" Padding="6,8" Margin="0,1">
                                    <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status icon chip -->
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                                Background="{Binding StatusTintBrush}" VerticalAlignment="Center">
                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                      Glyph="{Binding StatusGlyph}" FontSize="15" Foreground="{Binding StatusBrush}"/>
                                        </Border>

                                        <!-- Title + objective + (optional) target line -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ObjectiveSummary}" Style="{StaticResource LDMuted}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding TargetSummary}" Visibility="{Binding TargetVisibility}"
                                                       FontSize="11" Foreground="{Binding StatusBrush}" Opacity="0.9"/>
                                        </StackPanel>

                                        <!-- Status pill -->
                                        <Border Grid.Column="2" CornerRadius="10" Padding="9,3" Background="{Binding StatusTintBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{Binding StatusBrush}"/>
                                        </Border>

                                        <FontIcon Grid.Column="3" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="12" Opacity="0.35" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ═══ PENILAIAN SECTION ═══ -->
            <Border x:Name="GradingCard" Style="{StaticResource LDCard}" Visibility="Collapsed">
                <StackPanel Spacing="14">

                    <!-- Header penilaian -->
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border Width="38" Height="38" CornerRadius="10" Background="{StaticResource TintBlue}">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE9D2;" FontSize="17" Foreground="{StaticResource AccentBlue}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="Penilaian" Style="{StaticResource LDCardTitle}"/>
                                <TextBlock x:Name="GradingSubtitle" Text="" Style="{StaticResource LDMuted}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center">
                            <!-- Kelas filter (hanya tampil untuk Dosen) -->
                            <ComboBox x:Name="KelasFilterCombo" MinWidth="110" FontSize="12"
                                      Visibility="Collapsed"
                                      SelectionChanged="KelasFilterCombo_SelectionChanged"
                                      ToolTipService.ToolTip="Filter berdasarkan kelas"/>
                            <ComboBox x:Name="GradingAssignmentCombo" MinWidth="220" FontSize="12"
                                      SelectionChanged="GradingAssignmentCombo_SelectionChanged"/>
                            <Button x:Name="ManageStudentsBtn" FontSize="12" Padding="10,4"
                                    Click="ManageStudents_Click" Visibility="Collapsed"
                                    ToolTipService.ToolTip="Kelola Daftar Mahasiswa">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE8D3;" FontSize="12"/>
                                    <TextBlock Text="Kelola Mahasiswa" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button FontSize="12" Padding="10,4" Click="GradingRefresh_Click">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- ══ MAHASISWA: Pivot 3 tab ══ -->
                    <Pivot x:Name="StudentGradingPivot" Visibility="Collapsed"
                           SelectionChanged="StudentGradingPivot_SelectionChanged">

                        <!-- Tab 1: Nilai Rekan Kelompok -->
                        <PivotItem Header="Nilai Rekan Kelompok">
                            <StackPanel Spacing="14" Margin="0,12,0,0">
                                <InfoBar x:Name="GradingInfoBar" IsOpen="False" IsClosable="True"/>
                                <TextBlock Text="Anggota Kelompokmu" FontSize="13" FontWeight="SemiBold"/>

                                <ItemsRepeater x:Name="GroupMembersRepeater">
                                    <ItemsRepeater.Layout><StackLayout Spacing="10"/></ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <PersonPicture Grid.Column="0" Width="40" Height="40" Initials="{Binding Initials}"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock Text="{Binding StudentName}" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding StudentId}" FontSize="11" Opacity="0.5"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                        <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                                BorderBrush="{ThemeResource SystemFillColorSuccessBrush}"
                                                                BorderThickness="1" CornerRadius="4" Padding="8,3"
                                                                Visibility="{Binding AlreadyRatedVisibility}">
                                                            <TextBlock Text="Sudah Dinilai" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                                        </Border>
                                                        <Button Tag="{Binding StudentId}" Content="Nilai"
                                                                Style="{ThemeResource AccentButtonStyle}"
                                                                FontSize="12" Padding="12,4"
                                                                Click="NilaiSekarang_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <!-- Form penilaian peer -->
                                <Border x:Name="PeerFormCard" Visibility="Collapsed"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        BorderThickness="2" CornerRadius="10" Padding="20,16">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <TextBlock x:Name="FormTargetName" Text="Menilai: —"
                                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button HorizontalAlignment="Right" Content="Tutup" FontSize="12"
                                                    Click="ClosePeerForm_Click"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Opacity="0.5"/>
                                        <Grid ColumnSpacing="20" RowSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                                <Grid>
                                                    <TextBlock Text="Kontribusi Kerja" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="GContribScore" HorizontalAlignment="Right" Text="75" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                </Grid>
                                                <Slider x:Name="GSliderContrib" Minimum="0" Maximum="100" Value="75" StepFrequency="1" ValueChanged="GSlider_ValueChanged" Tag="Contrib"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                                <Grid>
                                                    <TextBlock Text="Kerjasama Tim" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="GCoopScore" HorizontalAlignment="Right" Text="75" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                </Grid>
                                                <Slider x:Name="GSliderCoop" Minimum="0" Maximum="100" Value="75" StepFrequency="1" ValueChanged="GSlider_ValueChanged" Tag="Coop"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                                <Grid>
                                                    <TextBlock Text="Tanggung Jawab" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="GRespScore" HorizontalAlignment="Right" Text="75" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                </Grid>
                                                <Slider x:Name="GSliderResp" Minimum="0" Maximum="100" Value="75" StepFrequency="1" ValueChanged="GSlider_ValueChanged" Tag="Resp"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                                <Grid>
                                                    <TextBlock Text="Kreativitas" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="GCreatScore" HorizontalAlignment="Right" Text="75" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                </Grid>
                                                <Slider x:Name="GSliderCreat" Minimum="0" Maximum="100" Value="75" StepFrequency="1" ValueChanged="GSlider_ValueChanged" Tag="Creat"/>
                                            </StackPanel>
                                        </Grid>
                                        <Border Background="{ThemeResource AccentFillColorTertiaryBrush}" CornerRadius="6" Padding="14,8">
                                            <Grid>
                                                <TextBlock Text="Rata-rata Nilai" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="GAveragePreview" HorizontalAlignment="Right" Text="75.0"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            </Grid>
                                        </Border>
                                        <TextBox x:Name="GPeerCommentBox" Header="Komentar (opsional)"
                                                 PlaceholderText="Tulis komentar tentang kontribusi rekan ini..."
                                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxLength="500"/>
                                        <Button Content="Kirim Penilaian"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                HorizontalAlignment="Right" MinWidth="140" FontSize="12"
                                                Click="GSubmitPeer_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </PivotItem>

                        <!-- Tab 2: Nilai yang Diterima -->
                        <PivotItem Header="Nilai yang Diterima">
                            <StackPanel Spacing="16" Margin="0,12,0,0">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1" CornerRadius="8" Padding="14,12">
                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE716;" FontSize="13" Foreground="{StaticResource AccentBlue}"/>
                                                <TextBlock Text="Nilai Peer" FontSize="11" Opacity="0.7"/>
                                            </StackPanel>
                                            <TextBlock x:Name="GMyPeerScore" Text="—" FontSize="22" FontWeight="Bold"/>
                                            <TextBlock x:Name="GMyPeerCount" Text="0 penilai" FontSize="11" Opacity="0.5"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1" CornerRadius="8" Padding="14,12">
                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE9D9;" FontSize="13" Foreground="#0078D4"/>
                                                <TextBlock Text="Nilai Sistem" FontSize="11" Opacity="0.7"/>
                                            </StackPanel>
                                            <TextBlock x:Name="GMySystemScore" Text="—" FontSize="22" FontWeight="Bold"/>
                                            <TextBlock Text="Berdasarkan aktivitas" FontSize="11" Opacity="0.5"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1" CornerRadius="8" Padding="14,12">
                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE7EF;" FontSize="13" Foreground="#107C10"/>
                                                <TextBlock Text="Nilai Dosen" FontSize="11" Opacity="0.7"/>
                                            </StackPanel>
                                            <TextBlock x:Name="GMyLecturerScore" Text="Belum" FontSize="22" FontWeight="Bold"/>
                                            <TextBlock Text="Dari dosen pengampu" FontSize="11" Opacity="0.5"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="Penilaian dari Rekan" FontSize="13" FontWeight="SemiBold"/>
                                <ItemsRepeater x:Name="GReceivedEvalRepeater">
                                    <ItemsRepeater.Layout><StackLayout Spacing="8"/></ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <PersonPicture Grid.Column="0" Width="36" Height="36" Initials="{Binding EvaluatorInitials}"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock Text="{Binding EvaluatorName}" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Comment}" FontSize="11" Opacity="0.6" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding EvaluatedAtStr}" FontSize="11" Opacity="0.4"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" CornerRadius="6" Background="{ThemeResource AccentFillColorTertiaryBrush}" Padding="10,5" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ScoreStr}" FontSize="16" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <TextBlock Text="Detail Nilai Sistem" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16,14">
                                    <Grid ColumnSpacing="24" RowSpacing="10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="Percobaan Tuning Unik" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GSysCommits" Text="—" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1">
                                            <TextBlock Text="Sesi Simulasi" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GSysFiles" Text="—" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="Sesi AI Produktif" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GSysOnTime" Text="—" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="Total Aktivitas" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GSysTasks" Text="—" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                CornerRadius="6" Padding="10,6"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                          Glyph="&#xE9D2;" FontSize="12" Opacity="0.6"/>
                                                <TextBlock Text="Tuning (maks 40) + AI (maks 20) + Simulasi (maks 40)"
                                                           FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </PivotItem>

                        <!-- Tab 3: Aktivitas Kelompok -->
                        <PivotItem Header="Aktivitas Kelompok">
                            <StackPanel Spacing="12" Margin="0,12,0,0">
                                <TextBlock Text="Aktivitas Terbaru Kelompok" FontSize="13" FontWeight="SemiBold"/>
                                <ItemsRepeater x:Name="GStuActivitiesRepeater">
                                    <ItemsRepeater.Layout><StackLayout Spacing="8"/></ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="7" Padding="12,10">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17"
                                                            Background="{ThemeResource AccentFillColorTertiaryBrush}">
                                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                  Glyph="{Binding ActivityIcon}" FontSize="14"
                                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding StudentName}" FontSize="13" FontWeight="SemiBold"/>
                                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="3" Padding="5,1">
                                                                <TextBlock Text="{Binding ActivityType}" FontSize="11" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" FontSize="11" Opacity="0.4" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </PivotItem>
                    </Pivot>

                    <!-- ══ DOSEN/ASISTEN: Pivot 4 tab ══ -->
                    <Pivot x:Name="LecturerGradingPivot" Visibility="Collapsed"
                           SelectionChanged="LecturerGradingPivot_SelectionChanged">

                        <!-- Tab 1: Rekap Nilai -->
                        <PivotItem Header="Rekap Nilai">
                            <StackPanel Spacing="14" Margin="0,12,0,0">
                                <!-- Stats -->
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Total Mahasiswa" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GLecStatTotal" Text="—" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Sudah Dinilai Dosen" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GLecStatGraded" Text="—" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Rata-rata Kelas" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GLecStatAvg" Text="—" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Peer Selesai" FontSize="11" Opacity="0.6"/>
                                            <TextBlock x:Name="GLecStatPeer" Text="—" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Tabel summary -->
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8">
                                    <StackPanel>
                                        <Grid Padding="14,10" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="55"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Mahasiswa" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="Kelompok" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="Peer" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="Sistem" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="Dosen" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Final" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="Grade" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="7" Text="Aksi" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                        <ItemsRepeater x:Name="GLecSummaryRepeater">
                                            <ItemsRepeater.Layout><StackLayout/></ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderThickness="0,0,0,1"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                                        <StackPanel>
                                                            <!-- Baris ringkasan -->
                                                            <Grid Padding="14,10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="160"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="55"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding StudentName}" FontSize="13" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding StudentId}" FontSize="11" Opacity="0.5"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1" Text="{Binding GroupName}" FontSize="13" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding PeerScoreStr}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding SystemScoreStr}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="4" Text="{Binding LecturerScoreStr}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="5" Text="{Binding FinalScoreStr}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <Border Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Background="{Binding GradeBadgeColor}" CornerRadius="4" Padding="7,2">
                                                                    <TextBlock Text="{Binding LetterGrade}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="6"
                                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Button Tag="{Binding StudentId}" Content="Detail"
                                                                            FontSize="12" Padding="10,4"
                                                                            Click="GLecShowDetail_Click"/>
                                                                    <Button Tag="{Binding StudentId}" Content="Nilai"
                                                                            Style="{ThemeResource AccentButtonStyle}"
                                                                            FontSize="12" Padding="10,4"
                                                                            Click="GLecGradeStudent_Click"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Expander: Detail persentase + breakdown sistem -->
                                                            <Expander Header="▼  Detail Penilaian"
                                                                      IsExpanded="True"
                                                                      Margin="14,0,14,10"
                                                                      HorizontalAlignment="Stretch"
                                                                      HorizontalContentAlignment="Stretch">
                                                                <StackPanel Spacing="8" Margin="0,6,0,0">

                                                                    <!-- Rekap persentase bobot -->
                                                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                            CornerRadius="8" Padding="14,10">
                                                                        <StackPanel Spacing="5">
                                                                            <TextBlock Text="Persentase Kontribusi Nilai Final"
                                                                                       FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                                                                            <TextBlock Text="{Binding PeerContribStr}"
                                                                                       FontSize="12" FontFamily="Consolas,Courier New"/>
                                                                            <TextBlock Text="{Binding SystemContribStr}"
                                                                                       FontSize="12" FontFamily="Consolas,Courier New"/>
                                                                            <TextBlock Text="{Binding LecturerContribStr}"
                                                                                       FontSize="12" FontFamily="Consolas,Courier New"/>
                                                                            <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,2"/>
                                                                            <TextBlock Text="{Binding WeightInfoStr}"
                                                                                       FontSize="12" FontWeight="SemiBold"
                                                                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <!-- Breakdown skor sistem (3 parameter) -->
                                                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                            CornerRadius="8" Padding="14,10">
                                                                        <StackPanel Spacing="5">
                                                                            <TextBlock Text="Parameter Skor Sistem"
                                                                                       FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                                                                            <TextBlock Text="{Binding TuningBreakdownStr}"
                                                                                       FontSize="12" TextWrapping="Wrap"/>
                                                                            <TextBlock Text="{Binding AiBreakdownStr}"
                                                                                       FontSize="12" TextWrapping="Wrap"/>
                                                                            <TextBlock Text="{Binding SimBreakdownStr}"
                                                                                       FontSize="12" TextWrapping="Wrap"/>
                                                                        </StackPanel>
                                                                    </Border>

                                                                </StackPanel>
                                                            </Expander>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </PivotItem>

                        <!-- Tab 2: Penilaian Peer -->
                        <PivotItem Header="Penilaian Peer">
                            <StackPanel Spacing="12" Margin="0,12,0,0">
                                <TextBlock Text="Penilaian Mahasiswa ke Mahasiswa" FontSize="13" FontWeight="SemiBold"/>
                                <ItemsRepeater x:Name="GLecPeerRepeater">
                                    <ItemsRepeater.Layout><StackLayout Spacing="8"/></ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding EvaluatorName}" FontSize="13" FontWeight="SemiBold"/>
                                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE72A;" FontSize="11" Opacity="0.5"/>
                                                            <TextBlock Text="{Binding EvaluateeName}" FontSize="13" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Comment}" FontSize="11" Opacity="0.6" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding EvaluatedAtStr}" FontSize="11" Opacity="0.4"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding SubScoresStr}" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="2" CornerRadius="6" Background="{ThemeResource AccentFillColorTertiaryBrush}" Padding="10,5" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ScoreStr}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                    </Border>
                                                    <Button Grid.Column="3" Tag="{Binding EvaluateeId}" Content="Detail"
                                                            FontSize="12" Padding="10,4" VerticalAlignment="Center"
                                                            Click="GLecDetailAny_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </PivotItem>

                        <!-- Tab 3: Penilaian Sistem -->
                        <PivotItem Header="Penilaian Sistem">
                            <StackPanel Spacing="12" Margin="0,12,0,0">

                                <!-- Keterangan bobot komponen -->
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="8" Padding="14,10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Komponen Skor Sistem (Total maks 100)"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                        <Grid ColumnSpacing="12" RowSpacing="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Tuning -->
                                            <Border Grid.Row="0" Grid.Column="0" CornerRadius="4" Padding="8,3"
                                                    Background="{StaticResource TintBlue}">
                                                <TextBlock Text="maks 40 poin" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBlue}"/>
                                            </Border>
                                            <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="Rekam Tuning Parameter" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="Eksplorasi variasi Kp/Ki/Kd (maks 15) + kualitas tuning terbaik (maks 25)"
                                                           FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                            <!-- AI -->
                                            <Border Grid.Row="1" Grid.Column="0" CornerRadius="4" Padding="8,3"
                                                    Background="{StaticResource TintPurple}">
                                                <TextBlock Text="maks 20 poin" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentPurple}"/>
                                            </Border>
                                            <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="Hasil Penggunaan AI" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="Sesi AI produktif × 5 poin"
                                                           FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                            <!-- Simulasi -->
                                            <Border Grid.Row="2" Grid.Column="0" CornerRadius="4" Padding="8,3"
                                                    Background="{StaticResource TintGreen}">
                                                <TextBlock Text="maks 40 poin" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentGreen}"/>
                                            </Border>
                                            <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="Hasil Simulasi" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="Skor simulasi terbaik × 40%"
                                                           FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Skor Sistem per Mahasiswa (berdasarkan 3 parameter)"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <ItemsRepeater x:Name="GLecSystemRepeater">
                                    <ItemsRepeater.Layout><StackLayout Spacing="8"/></ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="8" Padding="0">
                                                <StackPanel>
                                                    <!-- Baris header: nama + skor + aksi -->
                                                    <Grid Padding="14,12" ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                                            <TextBlock Text="{Binding StudentName}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding StudentId}"   FontSize="11" Opacity="0.5"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                                                            <!-- Chip tuning -->
                                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                    CornerRadius="4" Padding="8,4">
                                                                <TextBlock Text="{Binding TuningStr}" FontSize="11"/>
                                                            </Border>
                                                            <!-- Chip AI -->
                                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                    CornerRadius="4" Padding="8,4">
                                                                <TextBlock Text="{Binding AiStr}" FontSize="11"/>
                                                            </Border>
                                                            <!-- Chip simulasi + status -->
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                        CornerRadius="4" Padding="8,4">
                                                                    <TextBlock Text="{Binding SimStr}" FontSize="11"/>
                                                                </Border>
                                                                <Border CornerRadius="4" Padding="8,4" Background="{Binding OnTimeBg}">
                                                                    <TextBlock Text="{Binding OnTimeStr}" FontSize="11"
                                                                               FontWeight="SemiBold" Foreground="{Binding OnTimeFg}"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" CornerRadius="8"
                                                                Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                                Padding="10,6" VerticalAlignment="Center">
                                                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                                                <TextBlock Text="{Binding ScoreStr}" FontSize="18" FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                                <TextBlock Text="/ 100" FontSize="10" Opacity="0.6"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Button Grid.Column="3" Tag="{Binding StudentId}" Content="Detail"
                                                                FontSize="12" Padding="10,4" VerticalAlignment="Center"
                                                                Click="GLecDetailAny_Click"/>
                                                    </Grid>

                                                    <!-- Expander detail tuning + simulasi -->
                                                    <Expander Header="Detail Parameter Sistem"
                                                              Margin="10,0,10,10"
                                                              HorizontalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch">
                                                        <StackPanel Spacing="6" Margin="4,4,4,0">
                                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                    CornerRadius="6" Padding="12,8">
                                                                <StackPanel Spacing="3">
                                                                    <TextBlock Text="Rekam Tuning Parameter (maks 40 poin)"
                                                                               FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                                                                    <TextBlock Text="{Binding TuningDetailStr}"
                                                                               FontSize="12" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                    CornerRadius="6" Padding="12,8">
                                                                <StackPanel Spacing="3">
                                                                    <TextBlock Text="Hasil Simulasi (maks 40 poin)"
                                                                               FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                                                                    <TextBlock Text="{Binding SimDetailStr}"
                                                                               FontSize="12" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                    CornerRadius="6" Padding="12,8">
                                                                <StackPanel Spacing="3">
                                                                    <TextBlock Text="Penggunaan AI (maks 20 poin)"
                                                                               FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                                                                    <TextBlock Text="{Binding AiStr}"
                                                                               FontSize="12" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </PivotItem>

                        <!-- Tab 4: Rekap Submit (waktu submit vs deadline) -->
                        <PivotItem Header="Rekap Submit">
                            <StackPanel Spacing="12" Margin="0,12,0,0">

                                <!-- Header: judul + info deadline -->
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="Submit Mahasiswa" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="GLecSubmitCount" Text="" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" CornerRadius="6" Padding="10,5"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE916;"
                                                      FontSize="12" Opacity="0.7"/>
                                            <TextBlock x:Name="GLecDeadlineInfo" Text="Deadline: —"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Tabel submit -->
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8">
                                    <StackPanel>
                                        <!-- Header kolom -->
                                        <Grid Padding="14,10" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="88"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Mahasiswa"              FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="Kelompok"               FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="Deadline"               FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="3" Text="Waktu Submit"           FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="4" Text="Status"                 FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Selisih dari Deadline"  FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="6" Text="Aksi"                   FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </Grid>
                                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}"/>

                                        <ItemsRepeater x:Name="GLecSubmitRepeater">
                                            <ItemsRepeater.Layout><StackLayout/></ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,10" BorderThickness="0,0,0,1"
                                                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="88"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Mahasiswa -->
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                                            <TextBlock Text="{Binding StudentName}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding StudentId}"   FontSize="11" Opacity="0.5"/>
                                                        </StackPanel>

                                                        <!-- Kelompok -->
                                                        <TextBlock Grid.Column="1" Text="{Binding GroupName}"
                                                                   FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>

                                                        <!-- Deadline -->
                                                        <TextBlock Grid.Column="2" Text="{Binding DeadlineStr}"
                                                                   FontSize="12" VerticalAlignment="Center"/>

                                                        <!-- Waktu Submit -->
                                                        <TextBlock Grid.Column="3" Text="{Binding SubmitTimeStr}"
                                                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                                        <!-- Status pill -->
                                                        <Border Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                Background="{Binding StatusBg}" CornerRadius="6" Padding="8,3">
                                                            <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{Binding StatusFg}"/>
                                                        </Border>

                                                        <!-- Selisih -->
                                                        <TextBlock Grid.Column="5" Text="{Binding TimeDiffStr}"
                                                                   FontSize="11" Foreground="{Binding StatusFg}" VerticalAlignment="Center"/>

                                                        <!-- Aksi: Detail -->
                                                        <Button Grid.Column="6" Tag="{Binding StudentId}" Content="Detail"
                                                                FontSize="12" Padding="10,4" VerticalAlignment="Center"
                                                                Click="GLecDetailAny_Click"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>



                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </PivotItem>

                        <!-- Tab 5: Aktivitas Kelompok -->
                        <PivotItem Header="Aktivitas">
                            <StackPanel Spacing="12" Margin="0,12,0,0">
                                <TextBlock Text="Recent Activities — Semua Mahasiswa" FontSize="13" FontWeight="SemiBold"/>
                                <ItemsRepeater x:Name="GLecActivitiesRepeater">
                                    <ItemsRepeater.Layout><StackLayout Spacing="8"/></ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="7" Padding="12,10">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17"
                                                            Background="{ThemeResource AccentFillColorTertiaryBrush}">
                                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                  Glyph="{Binding ActivityIcon}" FontSize="14"
                                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding StudentName}" FontSize="13" FontWeight="SemiBold"/>
                                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="3" Padding="5,1">
                                                                <TextBlock Text="{Binding ActivityType}" FontSize="11" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="7,3"
                                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding AutoScoreStr}" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <!-- Waktu: absolut + relatif -->
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="1"
                                                                HorizontalAlignment="Right" Margin="6,0,0,0">
                                                        <TextBlock Text="{Binding ActivityTimeStr}" FontSize="11" Opacity="0.6" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding TimeAgo}"         FontSize="10" Opacity="0.4" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                    <!-- Detail -->
                                                    <Button Grid.Column="4" Tag="{Binding StudentId}" Content="Detail"
                                                            FontSize="12" Padding="10,4" VerticalAlignment="Center"
                                                            Click="GLecDetailAny_Click" Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </PivotItem>
                    </Pivot>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
