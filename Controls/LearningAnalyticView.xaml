<UserControl
    x:Class="TLIGDashboard.Controls.LearningAnalyticView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes">

    <UserControl.Resources>

        <!-- Accent palette — fixed colours, readable on both light & dark themes -->
        <SolidColorBrush x:Key="AccentGreen"  Color="#FF10B981"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#FF3B82F6"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#FF8B5CF6"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFF59E0B"/>

        <!-- Soft tints for icon chips / pills (~15% alpha) -->
        <SolidColorBrush x:Key="TintGreen"  Color="#2610B981"/>
        <SolidColorBrush x:Key="TintBlue"   Color="#263B82F6"/>
        <SolidColorBrush x:Key="TintPurple" Color="#268B5CF6"/>
        <SolidColorBrush x:Key="TintOrange" Color="#26F59E0B"/>

        <LinearGradientBrush x:Key="GaugeValueBrush" StartPoint="0,1" EndPoint="1,0">
            <GradientStop Color="#FF34D399" Offset="0"/>
            <GradientStop Color="#FF059669" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="LDCard" TargetType="Border">
            <Setter Property="Background"      Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="16"/>
        </Style>

        <Style x:Key="LDCardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="LDMuted" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity"  Value="0.6"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20,16,20,20">
        <StackPanel Spacing="14" MaxWidth="1180" HorizontalAlignment="Left">

            <!-- Page header -->
            <StackPanel Spacing="2" Margin="2,0,0,2">
                <TextBlock Text="{x:Bind Lang.Nav_LearningAnalytic, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind Lang.LearnDash_Subtitle, Mode=OneWay}"
                           Style="{StaticResource LDMuted}"/>
            </StackPanel>

            <!-- ═══ TOP BAND: overall performance (from tasks) · task summary ═══ -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <!-- Overall performance = % of tasks completed -->
                <Border Grid.Column="0" Style="{StaticResource LDCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.LearnDash_OverallPerf, Mode=OneWay}"
                                   Style="{StaticResource LDCardTitle}"/>
                        <TextBlock Text="{x:Bind Lang.LearnDash_CompletionRate, Mode=OneWay}"
                                   Style="{StaticResource LDMuted}"/>
                        <Grid Width="164" Height="104" Margin="0,8,0,0" HorizontalAlignment="Center">
                            <Canvas Width="164" Height="100">
                                <shapes:Path x:Name="GaugeTrack"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}"
                                             StrokeThickness="14"
                                             StrokeStartLineCap="Round"
                                             StrokeEndLineCap="Round"/>
                                <shapes:Path x:Name="GaugeValue"
                                             Stroke="{StaticResource GaugeValueBrush}"
                                             StrokeThickness="14"
                                             StrokeStartLineCap="Round"
                                             StrokeEndLineCap="Round"/>
                            </Canvas>
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <TextBlock x:Name="OverallPercentText" Text="0%" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="OverallSubText" Text="" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Task summary: total / completed / remaining -->
                <Border Grid.Column="1" Style="{StaticResource LDCard}">
                    <StackPanel Spacing="14" VerticalAlignment="Center">

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource TintBlue}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE9D5;" FontSize="18" Foreground="{StaticResource AccentBlue}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Lang.LearnDash_TotalTasks, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" x:Name="TotalTasksText" Text="0" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource TintGreen}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE930;" FontSize="18" Foreground="{StaticResource AccentGreen}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Lang.LearnDash_Completed, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" x:Name="DoneTasksText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource TintOrange}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE823;" FontSize="18" Foreground="{StaticResource AccentOrange}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Lang.LearnDash_Remaining, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" x:Name="RemainingTasksText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentOrange}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ TASKS LIST ═══ -->
            <Border Style="{StaticResource LDCard}">
                <StackPanel Spacing="10">
                    <!-- Title row + staff-only Add button -->
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Lang.LearnDash_TasksTitle, Mode=OneWay}" Style="{StaticResource LDCardTitle}"/>
                            <TextBlock x:Name="TaskCountText" Text="(0)" FontSize="15" FontWeight="SemiBold" Opacity="0.5" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="AddTaskBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                                FontSize="12" Padding="11,4" Visibility="Collapsed" Click="AddTask_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11"/>
                                <TextBlock Text="{x:Bind Lang.LearnDash_AddTask, Mode=OneWay}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock x:Name="EmptyText" Text="{x:Bind Lang.LearnDash_NoTasks, Mode=OneWay}"
                               Style="{StaticResource LDMuted}" Visibility="Collapsed" Margin="2,6,0,6"/>

                    <!-- Clickable task rows → detail page -->
                    <ItemsControl x:Name="TasksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="TaskRow_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        Background="Transparent" BorderThickness="0" Padding="6,8" Margin="0,1">
                                    <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status icon chip -->
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                                Background="{Binding StatusTintBrush}" VerticalAlignment="Center">
                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                      Glyph="{Binding StatusGlyph}" FontSize="15" Foreground="{Binding StatusBrush}"/>
                                        </Border>

                                        <!-- Title + objective + (optional) target line -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ObjectiveSummary}" Style="{StaticResource LDMuted}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding TargetSummary}" Visibility="{Binding TargetVisibility}"
                                                       FontSize="11" Foreground="{Binding StatusBrush}" Opacity="0.9"/>
                                        </StackPanel>

                                        <!-- Status pill -->
                                        <Border Grid.Column="2" CornerRadius="10" Padding="9,3" Background="{Binding StatusTintBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{Binding StatusBrush}"/>
                                        </Border>

                                        <FontIcon Grid.Column="3" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="12" Opacity="0.35" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
