<Page
    x:Class="TLIGDashboard.Views.UserManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TLIGDashboard.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="UserRowStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,2"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header: title + add button ── -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{x:Bind Lang.Um_Title, Mode=OneWay}"
                           FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind Lang.Um_Subtitle, Mode=OneWay}"
                           FontSize="12" Opacity="0.65"/>
            </StackPanel>
            <Button Grid.Column="1"
                    VerticalAlignment="Center"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="AddUser_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14" Glyph="&#xE8FA;"/>
                    <TextBlock Text="{x:Bind Lang.Um_AddUser, Mode=OneWay}"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Column headers ── -->
        <Border Grid.Row="1"
                Padding="12,8"
                CornerRadius="6"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Bind Lang.Um_ColUser, Mode=OneWay}"     FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                <TextBlock Grid.Column="1" Text="{x:Bind Lang.Um_ColName, Mode=OneWay}"     FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                <TextBlock Grid.Column="2" Text="{x:Bind Lang.Um_ColRole, Mode=OneWay}"     FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                <TextBlock Grid.Column="3" Text="{x:Bind Lang.Um_ColStatus, Mode=OneWay}"   FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                <TextBlock Grid.Column="4" Text="{x:Bind Lang.Um_ColLastLogin, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                <Border    Grid.Column="5" MinWidth="260"/>
            </Grid>
        </Border>

        <!-- ── User list ── -->
        <ListView Grid.Row="2"
                  x:Name="UsersList"
                  SelectionMode="None"
                  ItemContainerStyle="{StaticResource UserRowStyle}"
                  ScrollViewer.HorizontalScrollMode="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:UserRow">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{x:Bind Username}"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}"
                                   VerticalAlignment="Center" Opacity="0.85"
                                   TextTrimming="CharacterEllipsis"/>
                        <!-- NRP · Kelas -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="{x:Bind Nrp}"   FontSize="12" Opacity="0.9"
                                       Visibility="{x:Bind NrpVisible}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind Kelas}" FontSize="11" Opacity="0.65"
                                       Visibility="{x:Bind KelasVisible}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="—" FontSize="12" Opacity="0.4"
                                       Visibility="{x:Bind EmptyNrpKelasVisible}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="{x:Bind RoleLabel}"
                                   VerticalAlignment="Center" Opacity="0.85"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind StatusLabel}"
                                   VerticalAlignment="Center" Opacity="0.85"/>
                        <TextBlock Grid.Column="5" Text="{x:Bind LastLoginText}"
                                   VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>

                        <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center">
                            <Button FontSize="12" Padding="10,4"
                                    Tag="{x:Bind Username}"
                                    Click="ResetPwd_Click"
                                    Content="{x:Bind ResetLabel}"/>
                            <Button FontSize="12" Padding="10,4"
                                    Tag="{x:Bind Username}"
                                    Click="EditUser_Click"
                                    Content="{x:Bind EditLabel}"/>
                            <Button FontSize="12" Padding="10,4"
                                    Tag="{x:Bind Username}"
                                    Click="ToggleEnabled_Click"
                                    Content="{x:Bind ToggleLabel}"/>
                            <Button FontSize="12" Padding="10,4"
                                    Tag="{x:Bind Username}"
                                    Click="DeleteUser_Click"
                                    Content="{x:Bind DeleteLabel}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty-state message -->
        <TextBlock x:Name="EmptyText"
                   Grid.Row="2"
                   Text="{x:Bind Lang.Um_Empty, Mode=OneWay}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.6"
                   Visibility="Collapsed"/>
    </Grid>
</Page>
