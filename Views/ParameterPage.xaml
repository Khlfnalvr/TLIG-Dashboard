<Page
    x:Class="TLIGDashboard.Views.ParameterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24,20,24,20">
        <StackPanel Spacing="10" MaxWidth="540">

            <!-- Section title -->
            <TextBlock Text="{x:Bind Lang.Panel_ModelSistem, Mode=OneWay}"
                       FontSize="11" FontWeight="SemiBold"
                       CharacterSpacing="80" Opacity="0.55"
                       Margin="2,0,0,4"/>

            <!-- Diagram Blok -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16,12,16,16">
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Bind Lang.Panel_DiagramBlok, Mode=OneWay}"
                               FontSize="10" FontWeight="SemiBold"
                               CharacterSpacing="60" Opacity="0.55"/>
                    <Border Height="140" CornerRadius="6"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Parameter PID -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16,12,16,16">
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Bind Lang.Panel_ParameterPid, Mode=OneWay}"
                               FontSize="10" FontWeight="SemiBold"
                               CharacterSpacing="60" Opacity="0.55"/>
                    <Border Height="120" CornerRadius="6"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Respon Sistem -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16,12,16,16">
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Bind Lang.Panel_ResponSistem, Mode=OneWay}"
                               FontSize="10" FontWeight="SemiBold"
                               CharacterSpacing="60" Opacity="0.55"/>
                    <Border x:Name="ResponSistemChart"
                            Height="180" CornerRadius="6"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Metrics 2×2 -->
            <Grid ColumnSpacing="10" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16,12,16,16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind Lang.Panel_RiseTime, Mode=OneWay}"
                                   FontSize="10" FontWeight="SemiBold"
                                   CharacterSpacing="60" Opacity="0.55"/>
                        <TextBlock x:Name="RiseTimeValue"
                                   Text="--" FontSize="22" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16,12,16,16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind Lang.Panel_Overshoot, Mode=OneWay}"
                                   FontSize="10" FontWeight="SemiBold"
                                   CharacterSpacing="60" Opacity="0.55"/>
                        <TextBlock x:Name="OvershootValue"
                                   Text="--" FontSize="22" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16,12,16,16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind Lang.Panel_Settling, Mode=OneWay}"
                                   FontSize="10" FontWeight="SemiBold"
                                   CharacterSpacing="60" Opacity="0.55"/>
                        <TextBlock x:Name="SettlingValue"
                                   Text="--" FontSize="22" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16,12,16,16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind Lang.Panel_SteadyErr, Mode=OneWay}"
                                   FontSize="10" FontWeight="SemiBold"
                                   CharacterSpacing="60" Opacity="0.55"/>
                        <TextBlock x:Name="SteadyErrValue"
                                   Text="--" FontSize="22" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Transfer Function -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16,14,16,14">
                <TextBlock Text="{x:Bind Lang.Panel_TransferFunction, Mode=OneWay}"
                           FontSize="10" FontWeight="SemiBold"
                           CharacterSpacing="60" Opacity="0.55"
                           HorizontalAlignment="Center"/>
            </Border>

        </StackPanel>
    </ScrollViewer>

</Page>
