<Page
    x:Class="TLIGDashboard.Views.UserPerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TLIGDashboard.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentGreen"   Color="#FF10B981"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#FF3B82F6"/>
        <SolidColorBrush x:Key="AccentPurple"  Color="#FF8B5CF6"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#FFF59E0B"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#FFC42B1C"/>

        <SolidColorBrush x:Key="TintGreen"     Color="#2610B981"/>
        <SolidColorBrush x:Key="TintBlue"      Color="#263B82F6"/>
        <SolidColorBrush x:Key="TintPurple"    Color="#268B5CF6"/>
        <SolidColorBrush x:Key="TintOrange"    Color="#26F59E0B"/>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"      Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="16,12"/>
        </Style>
    </Page.Resources>

    <Grid Padding="28,20,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Padding="0,0,0,16"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{x:Bind Lang.Up_Title, Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind Lang.Up_Subtitle, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6"/>
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Glyph="&#xE72C;" FontSize="13"/>
                        <TextBlock Text="{x:Bind Lang.Up_Refresh, Mode=OneWay}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,16,0,0">
            <StackPanel Spacing="18">

                <!-- ── Stats Bar ── -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{x:Bind Lang.Up_StatTotalUsers, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatTotal" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource StatCard}">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{x:Bind Lang.Up_StatAvgTasks, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatAvgTasks" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{x:Bind Lang.Up_StatAvgScore, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatAvgScore" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource StatCard}">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{x:Bind Lang.Up_StatGraded, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatGraded" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Column headers ── -->
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        Padding="16,10" CornerRadius="6">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Lang.Up_ColUser, Mode=OneWay}"          FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind Lang.Up_ColProgress, Mode=OneWay}"      FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Lang.Up_ColSimulation, Mode=OneWay}"    FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                        <TextBlock Grid.Column="3" Text="{x:Bind Lang.Up_ColSystem, Mode=OneWay}"        FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind Lang.Up_ColLecturer, Mode=OneWay}"      FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                        <TextBlock Grid.Column="5" Text="{x:Bind Lang.Up_ColFinal, Mode=OneWay}"         FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                        <TextBlock Grid.Column="6" Text="{x:Bind Lang.Up_ColGrade, Mode=OneWay}"         FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
                    </Grid>
                </Border>

                <!-- ── User performance list (clickable rows) ── -->
                <ItemsRepeater x:Name="UserListRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="6"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <!-- Wrap in Button so the whole row is clickable -->
                            <Button HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Click="UserRow_Click">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16,10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.6*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="0.9*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- User info -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Username}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"/>
                                                <Border Background="{Binding RoleTintBrush}"
                                                        CornerRadius="3" Padding="5,1">
                                                    <TextBlock Text="{Binding RoleLabel}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               FontSize="10"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Task progress -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                            <TextBlock Text="{Binding TaskProgressText}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       FontWeight="SemiBold"/>
                                            <Grid>
                                                <Rectangle Height="6" Fill="{ThemeResource ControlFillColorSecondaryBrush}"
                                                           RadiusX="3" RadiusY="3"/>
                                                <Rectangle Height="6" RadiusX="3" RadiusY="3"
                                                           Fill="{Binding ProgressFillBrush}"
                                                           HorizontalAlignment="Left"
                                                           Width="{Binding ProgressBarWidth}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Peer / Simulation scores -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding PeerScoreStr}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding PeerLabel}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.4" FontSize="10"/>
                                        </StackPanel>

                                        <!-- System score -->
                                        <Border Grid.Column="3"
                                                CornerRadius="6" Padding="10,5"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SystemScoreStr}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       FontWeight="SemiBold"/>
                                        </Border>

                                        <!-- Lecturer score -->
                                        <Border Grid.Column="4"
                                                CornerRadius="6" Padding="10,5"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding LecturerScoreStr}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       FontWeight="SemiBold"/>
                                        </Border>

                                        <!-- Final score -->
                                        <Border Grid.Column="5"
                                                CornerRadius="6" Padding="10,5"
                                                Background="{Binding FinalScoreBgBrush}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding FinalScoreStr}"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding FinalScoreFgBrush}"/>
                                        </Border>

                                        <!-- Grade badge -->
                                        <Border Grid.Column="6"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Background="{Binding GradeBadgeColor}"
                                                CornerRadius="4" Padding="10,4">
                                            <TextBlock Text="{Binding LetterGrade}"
                                                       FontWeight="Bold"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyText"
                           Text="{x:Bind Lang.Up_Empty, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           Opacity="0.6"
                           Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
