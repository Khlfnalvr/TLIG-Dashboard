<Page
    x:Class="TLIGDashboard.Views.LoggingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TLIGDashboard.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedActivities" IsSourceGrouped="True"/>

        <Style x:Key="ActivityRowStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <Style x:Key="GroupHeaderStyle" TargetType="ListViewHeaderItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24,20,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- filter bar -->
            <RowDefinition Height="Auto"/>   <!-- summary cards -->
            <RowDefinition Height="160"/>    <!-- bar chart -->
            <RowDefinition Height="*"/>      <!-- grouped list -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Log Aktivitas Pembelajaran"
                           FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="Rekap seluruh aktivitas pengguna selama proses pembelajaran dan pengerjaan challenge"
                           FontSize="12" Opacity="0.6"/>
            </StackPanel>
            <Button x:Name="ExportBtn" Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="ExportBtn_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="13" Glyph="&#xE896;"/>
                    <TextBlock Text="Export Excel"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Filter bar ── -->
        <Border Grid.Row="1" Padding="12,10" CornerRadius="8"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="148"/>
                    <ColumnDefinition Width="148"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SearchBox"
                         PlaceholderText="Cari nama / username..."
                         TextChanged="Filter_Changed"/>
                <ComboBox Grid.Column="1" x:Name="CategoryFilter"
                          PlaceholderText="Semua kategori"
                          SelectionChanged="Filter_Changed"
                          HorizontalAlignment="Stretch"/>
                <DatePicker Grid.Column="2" x:Name="FromDatePicker"
                            DateChanged="Filter_Changed"/>
                <DatePicker Grid.Column="3" x:Name="ToDatePicker"
                            DateChanged="Filter_Changed"/>
                <Button Grid.Column="4" x:Name="RefreshBtn"
                        ToolTipService.ToolTip="Muat ulang"
                        Click="RefreshBtn_Click">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="13" Glyph="&#xE72C;"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Summary cards ── -->
        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Background="#1A6EA6">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Glyph="&#xE9D9;" FontSize="16" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="TotalText" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Total Aktivitas" FontSize="10" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Background="#1A7A4A">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Glyph="&#xE8D3;" FontSize="16" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="LoginCountText" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Sesi Login" FontSize="10" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Background="#1A6B5A">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Glyph="&#xE8BD;" FontSize="16" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="AiCountText" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="AI Query" FontSize="10" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Background="#7A4A1A">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Glyph="&#xE8A5;" FontSize="16" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="TaskCountText" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Submit Tugas" FontSize="10" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Background="#6A2A6A">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Glyph="&#xE9F5;" FontSize="16" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Name="SimCountText" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Simulasi" FontSize="10" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Bar chart: aktivitas per hari (14 hari terakhir) ── -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16,12">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="AKTIVITAS PER HARI — 14 HARI TERAKHIR"
                           FontSize="10" FontWeight="SemiBold"
                           CharacterSpacing="60" Opacity="0.55"/>
                <Canvas Grid.Row="1" x:Name="ChartCanvas"
                        SizeChanged="ChartCanvas_SizeChanged"/>
            </Grid>
        </Border>

        <!-- ── Grouped activity list ── -->
        <Grid Grid.Row="4" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <Border Grid.Row="0" Padding="12,7" CornerRadius="6,6,0,0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Waktu"     FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="1" Text="Nama"      FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="2" Text="Role"      FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="3" Text="Kategori"  FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="4" Text="Aksi"      FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="5" Text="Deskripsi" FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                </Grid>
            </Border>

            <!-- Grouped ListView -->
            <ListView Grid.Row="1"
                      x:Name="ActivityList"
                      SelectionMode="None"
                      ItemContainerStyle="{StaticResource ActivityRowStyle}"
                      ItemsSource="{x:Bind GroupedActivities.View, Mode=OneWay}">

                <ListView.GroupStyle>
                    <GroupStyle HeaderContainerStyle="{StaticResource GroupHeaderStyle}">
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Padding="12,6,12,6" Margin="0,4,0,0"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="4">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0"
                                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                  Glyph="&#xE787;" FontSize="11" Opacity="0.6"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Key}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CountLabel}"
                                                   FontSize="11" Opacity="0.55"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ActivityRow">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Timestamp}"
                                       FontSize="11" FontFamily="Consolas"
                                       VerticalAlignment="Center" Opacity="0.7"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}"
                                       FontSize="12" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Role}"
                                       FontSize="11" VerticalAlignment="Center" Opacity="0.7"
                                       TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Column="3" CornerRadius="4" Padding="6,2"
                                    Background="{x:Bind CategoryColor}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind CategoryLabel}"
                                           FontSize="10" Foreground="White"/>
                            </Border>
                            <TextBlock Grid.Column="4" Text="{x:Bind Action}"
                                       FontSize="11" VerticalAlignment="Center" Opacity="0.75"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="5" Text="{x:Bind Description}"
                                       FontSize="12" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind Description}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ── Status bar ── -->
        <TextBlock Grid.Row="5" x:Name="StatusText"
                   FontSize="11" Opacity="0.55" Margin="0,2,0,0"/>
    </Grid>
</Page>
