<Page
    x:Class="TLIGDashboard.Views.LearningAnalyticPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TLIGDashboard.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Tab button base style -->
        <Style x:Key="TabBtnBase" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="CornerRadius"     Value="6"/>
        </Style>
    </Page.Resources>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Tab bar ── -->
        <Border Grid.Row="0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8,16,0">
            <StackPanel Orientation="Horizontal" Spacing="4">

                <!-- Tab: Learning Analytic -->
                <Button x:Name="TabAnalyticBtn"
                        Content="Learning Analytic"
                        Style="{StaticResource TabBtnBase}"
                        FontWeight="SemiBold"
                        Click="TabAnalyticBtn_Click"/>

                <!-- Tab: Challenge -->
                <Button x:Name="TabChallengeBtn"
                        Content="Challenge"
                        Style="{StaticResource TabBtnBase}"
                        Click="TabChallengeBtn_Click"/>

            </StackPanel>
        </Border>

        <!-- ── Content area ── -->
        <Grid Grid.Row="1">

            <!-- Panel 1: Learning Analytic -->
            <controls:LearningAnalyticView x:Name="AnalyticView"/>

            <!-- Panel 2: Challenge (Frame — lazy-loaded) -->
            <Frame x:Name="ChallengeFrame"
                   Visibility="Collapsed"/>

        </Grid>
    </Grid>
</Page>
