<Page
    x:Class="TLIGDashboard.Views.LearningAnalyticPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>

        <!-- Accent palette — fixed colours, readable on both light & dark themes -->
        <SolidColorBrush x:Key="AccentGreen"  Color="#FF10B981"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#FF3B82F6"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#FF8B5CF6"/>
        <SolidColorBrush x:Key="AccentPink"   Color="#FFEC4899"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFF59E0B"/>
        <SolidColorBrush x:Key="AccentTeal"   Color="#FF14B8A6"/>

        <!-- Soft tints for icon chips / pills (~15% alpha) -->
        <SolidColorBrush x:Key="TintGreen"  Color="#2610B981"/>
        <SolidColorBrush x:Key="TintBlue"   Color="#263B82F6"/>
        <SolidColorBrush x:Key="TintPurple" Color="#268B5CF6"/>
        <SolidColorBrush x:Key="TintPink"   Color="#26EC4899"/>
        <SolidColorBrush x:Key="TintOrange" Color="#26F59E0B"/>
        <SolidColorBrush x:Key="TintTeal"   Color="#2614B8A6"/>

        <LinearGradientBrush x:Key="GaugeValueBrush" StartPoint="0,1" EndPoint="1,0">
            <GradientStop Color="#FF34D399" Offset="0"/>
            <GradientStop Color="#FF059669" Offset="1"/>
        </LinearGradientBrush>

        <!-- Card -->
        <Style x:Key="LDCard" TargetType="Border">
            <Setter Property="Background"      Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="16"/>
        </Style>

        <!-- Section / card title -->
        <Style x:Key="LDCardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Muted helper text -->
        <Style x:Key="LDMuted" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity"  Value="0.6"/>
        </Style>

        <!-- Column header in the courses table -->
        <Style x:Key="LDColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Opacity"      Value="0.55"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20,16,20,20">
        <StackPanel Spacing="14" MaxWidth="1180" HorizontalAlignment="Left">

            <!-- Page header -->
            <StackPanel Spacing="2" Margin="2,0,0,2">
                <TextBlock Text="{x:Bind Lang.Nav_LearningAnalytic, Mode=OneWay}"
                           FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind Lang.LearnDash_Subtitle, Mode=OneWay}"
                           Style="{StaticResource LDMuted}"/>
            </StackPanel>

            <!-- ═══ TOP BAND: overall performance · enroll stats · activity stats ═══ -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="1.15*"/>
                </Grid.ColumnDefinitions>

                <!-- Overall performance -->
                <Border Grid.Column="0" Style="{StaticResource LDCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.LearnDash_OverallPerf, Mode=OneWay}"
                                   Style="{StaticResource LDCardTitle}"/>
                        <TextBlock Text="{x:Bind Lang.LearnDash_CompletionRate, Mode=OneWay}"
                                   Style="{StaticResource LDMuted}"/>
                        <Grid Width="164" Height="100" Margin="0,8,0,0" HorizontalAlignment="Center">
                            <Canvas Width="164" Height="100">
                                <shapes:Path x:Name="GaugeTrack"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}"
                                             StrokeThickness="14"
                                             StrokeStartLineCap="Round"
                                             StrokeEndLineCap="Round"/>
                                <shapes:Path x:Name="GaugeValue"
                                             Stroke="{StaticResource GaugeValueBrush}"
                                             StrokeThickness="14"
                                             StrokeStartLineCap="Round"
                                             StrokeEndLineCap="Round"/>
                            </Canvas>
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <TextBlock Text="80%" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Lang.LearnDash_ProLearner, Mode=OneWay}"
                                           FontSize="10" FontWeight="SemiBold" Opacity="0.55"
                                           CharacterSpacing="100" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Enroll / completed / hours -->
                <Border Grid.Column="1" Style="{StaticResource LDCard}">
                    <StackPanel Spacing="16" VerticalAlignment="Center">

                        <!-- Total enroll courses -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                    Background="{StaticResource TintGreen}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE8F1;"
                                          FontSize="18" Foreground="{StaticResource AccentGreen}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       Text="{x:Bind Lang.LearnDash_TotalEnroll, Mode=OneWay}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <Grid Grid.Column="2" Width="54" Height="54">
                                <Canvas Width="54" Height="54">
                                    <Ellipse Width="42" Height="42" Canvas.Left="6" Canvas.Top="6"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}" StrokeThickness="5"/>
                                    <shapes:Path x:Name="RingEnroll" Stroke="{StaticResource AccentGreen}"
                                                 StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                                <TextBlock Text="5" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <!-- Course completed -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                    Background="{StaticResource TintTeal}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE930;"
                                          FontSize="18" Foreground="{StaticResource AccentTeal}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       Text="{x:Bind Lang.LearnDash_CourseCompleted, Mode=OneWay}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <Grid Grid.Column="2" Width="54" Height="54">
                                <Canvas Width="54" Height="54">
                                    <Ellipse Width="42" Height="42" Canvas.Left="6" Canvas.Top="6"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}" StrokeThickness="5"/>
                                    <shapes:Path x:Name="RingCompleted" Stroke="{StaticResource AccentTeal}"
                                                 StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                                <TextBlock Text="1" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <!-- Hours spent -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                    Background="{StaticResource TintPink}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE823;"
                                          FontSize="18" Foreground="{StaticResource AccentPink}"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="{x:Bind Lang.LearnDash_HoursSpent, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind Lang.LearnDash_HoursSpentSub, Mode=OneWay}"
                                           Style="{StaticResource LDMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Grid Grid.Column="2" Width="54" Height="54">
                                <Canvas Width="54" Height="54">
                                    <Ellipse Width="42" Height="42" Canvas.Left="6" Canvas.Top="6"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}" StrokeThickness="5"/>
                                    <shapes:Path x:Name="RingHours" Stroke="{StaticResource AccentPink}"
                                                 StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                                <TextBlock Text="112h" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Live / quiz / assignment -->
                <Border Grid.Column="2" Style="{StaticResource LDCard}">
                    <StackPanel Spacing="16" VerticalAlignment="Center">

                        <!-- Live class attended -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                    Background="{StaticResource TintOrange}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE768;"
                                          FontSize="17" Foreground="{StaticResource AccentOrange}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       Text="{x:Bind Lang.LearnDash_LiveAttended, Mode=OneWay}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <Grid Grid.Column="2" Width="54" Height="54">
                                <Canvas Width="54" Height="54">
                                    <Ellipse Width="42" Height="42" Canvas.Left="6" Canvas.Top="6"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}" StrokeThickness="5"/>
                                    <shapes:Path x:Name="RingLive" Stroke="{StaticResource AccentOrange}"
                                                 StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                                <TextBlock Text="70%" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <!-- Quiz practised -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                    Background="{StaticResource TintPurple}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE897;"
                                          FontSize="18" Foreground="{StaticResource AccentPurple}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       Text="{x:Bind Lang.LearnDash_QuizPractised, Mode=OneWay}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <Grid Grid.Column="2" Width="54" Height="54">
                                <Canvas Width="54" Height="54">
                                    <Ellipse Width="42" Height="42" Canvas.Left="6" Canvas.Top="6"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}" StrokeThickness="5"/>
                                    <shapes:Path x:Name="RingQuiz" Stroke="{StaticResource AccentPurple}"
                                                 StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                                <TextBlock Text="20/30" FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <!-- Assignment done -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                                    Background="{StaticResource TintBlue}" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE8A5;"
                                          FontSize="17" Foreground="{StaticResource AccentBlue}"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       Text="{x:Bind Lang.LearnDash_AssignmentDone, Mode=OneWay}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <Grid Grid.Column="2" Width="54" Height="54">
                                <Canvas Width="54" Height="54">
                                    <Ellipse Width="42" Height="42" Canvas.Left="6" Canvas.Top="6"
                                             Stroke="{ThemeResource ControlFillColorSecondaryBrush}" StrokeThickness="5"/>
                                    <shapes:Path x:Name="RingAssign" Stroke="{StaticResource AccentBlue}"
                                                 StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                                <TextBlock Text="10/15" FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ BOTTOM: courses table  +  assignment / pending quizzes ═══ -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Total courses table -->
                <Border Grid.Column="0" Style="{StaticResource LDCard}" VerticalAlignment="Top">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind Lang.LearnDash_TotalCourses, Mode=OneWay}"
                                       Style="{StaticResource LDCardTitle}"/>
                            <TextBlock Text="(5)" FontSize="15" FontWeight="SemiBold" Opacity="0.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Column headers -->
                        <Grid ColumnSpacing="12" Padding="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.4*"/>
                                <ColumnDefinition Width="1.7*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.7*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Lang.LearnDash_ColCourseName, Mode=OneWay}" Style="{StaticResource LDColHeader}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Lang.LearnDash_ColProgress, Mode=OneWay}"   Style="{StaticResource LDColHeader}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Lang.LearnDash_ColScore, Mode=OneWay}"      Style="{StaticResource LDColHeader}"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind Lang.LearnDash_ColStatus, Mode=OneWay}"     Style="{StaticResource LDColHeader}"/>
                        </Grid>

                        <!-- Row: Physics 1 -->
                        <Border BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="0,4,0,10">
                            <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.4*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource TintOrange}" VerticalAlignment="Center">
                                        <TextBlock Text="P" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentOrange}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="Physics 1" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Lang.LearnDash_CourseMeta, Mode=OneWay}" Style="{StaticResource LDMuted}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <ProgressBar Value="30" Maximum="100" Width="86" Height="5" VerticalAlignment="Center"
                                                 Foreground="{StaticResource AccentOrange}"/>
                                    <TextBlock Text="30%" FontSize="12" VerticalAlignment="Center" Opacity="0.75"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="80%" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Grid Grid.Column="3" ColumnSpacing="6" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" HorizontalAlignment="Left" CornerRadius="10" Padding="9,3" Background="{StaticResource TintOrange}">
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE823;" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                            <TextBlock Text="{x:Bind Lang.LearnDash_InProgress, Mode=OneWay}" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                        </StackPanel>
                                    </Border>
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="12" Opacity="0.35"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Row: Physics 2 -->
                        <Border BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="0,4,0,10">
                            <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.4*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource TintOrange}" VerticalAlignment="Center">
                                        <TextBlock Text="P" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentOrange}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="Physics 2" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Lang.LearnDash_CourseMeta, Mode=OneWay}" Style="{StaticResource LDMuted}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <ProgressBar Value="30" Maximum="100" Width="86" Height="5" VerticalAlignment="Center"
                                                 Foreground="{StaticResource AccentOrange}"/>
                                    <TextBlock Text="30%" FontSize="12" VerticalAlignment="Center" Opacity="0.75"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="80%" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Grid Grid.Column="3" ColumnSpacing="6" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" HorizontalAlignment="Left" CornerRadius="10" Padding="9,3" Background="{StaticResource TintOrange}">
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE823;" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                            <TextBlock Text="{x:Bind Lang.LearnDash_InProgress, Mode=OneWay}" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                        </StackPanel>
                                    </Border>
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="12" Opacity="0.35"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Row: Chemistry 1 -->
                        <Border BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="0,4,0,10">
                            <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.4*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource TintGreen}" VerticalAlignment="Center">
                                        <TextBlock Text="C" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="Chemistry 1" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Lang.LearnDash_CourseMeta, Mode=OneWay}" Style="{StaticResource LDMuted}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <ProgressBar Value="30" Maximum="100" Width="86" Height="5" VerticalAlignment="Center"
                                                 Foreground="{StaticResource AccentOrange}"/>
                                    <TextBlock Text="30%" FontSize="12" VerticalAlignment="Center" Opacity="0.75"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="70%" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Grid Grid.Column="3" ColumnSpacing="6" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" HorizontalAlignment="Left" CornerRadius="10" Padding="9,3" Background="{StaticResource TintOrange}">
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE823;" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                            <TextBlock Text="{x:Bind Lang.LearnDash_InProgress, Mode=OneWay}" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                        </StackPanel>
                                    </Border>
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="12" Opacity="0.35"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Row: Chemistry 2 -->
                        <Border BorderThickness="0,0,0,1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="0,4,0,10">
                            <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.4*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.7*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource TintGreen}" VerticalAlignment="Center">
                                        <TextBlock Text="C" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="Chemistry 2" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Lang.LearnDash_CourseMeta, Mode=OneWay}" Style="{StaticResource LDMuted}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <ProgressBar Value="30" Maximum="100" Width="86" Height="5" VerticalAlignment="Center"
                                                 Foreground="{StaticResource AccentOrange}"/>
                                    <TextBlock Text="30%" FontSize="12" VerticalAlignment="Center" Opacity="0.75"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="80%" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Grid Grid.Column="3" ColumnSpacing="6" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" HorizontalAlignment="Left" CornerRadius="10" Padding="9,3" Background="{StaticResource TintOrange}">
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE823;" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                            <TextBlock Text="{x:Bind Lang.LearnDash_InProgress, Mode=OneWay}" FontSize="11" Foreground="{StaticResource AccentOrange}"/>
                                        </StackPanel>
                                    </Border>
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="12" Opacity="0.35"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Row: Higher math 1 (completed) -->
                        <Grid ColumnSpacing="12" VerticalAlignment="Center" Padding="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.4*"/>
                                <ColumnDefinition Width="1.7*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.7*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource TintTeal}" VerticalAlignment="Center">
                                    <TextBlock Text="H" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentTeal}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                    <TextBlock Text="Higher math 1" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Lang.LearnDash_CourseMeta, Mode=OneWay}" Style="{StaticResource LDMuted}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <ProgressBar Value="100" Maximum="100" Width="86" Height="5" VerticalAlignment="Center"
                                             Foreground="{StaticResource AccentGreen}"/>
                                <TextBlock Text="100%" FontSize="12" VerticalAlignment="Center" Opacity="0.75"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="90%" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Grid Grid.Column="3" ColumnSpacing="6" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" HorizontalAlignment="Left" CornerRadius="10" Padding="9,3" Background="{StaticResource TintGreen}">
                                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE930;" FontSize="11" Foreground="{StaticResource AccentGreen}"/>
                                        <TextBlock Text="{x:Bind Lang.LearnDash_Completed, Mode=OneWay}" FontSize="11" Foreground="{StaticResource AccentGreen}"/>
                                    </StackPanel>
                                </Border>
                                <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="12" Opacity="0.35"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Right column: assignment + pending quizzes -->
                <StackPanel Grid.Column="1" Spacing="14">

                    <!-- Assignment -->
                    <Border Style="{StaticResource LDCard}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{x:Bind Lang.LearnDash_Assignment, Mode=OneWay}" Style="{StaticResource LDCardTitle}"/>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="{StaticResource TintBlue}" VerticalAlignment="Top">
                                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE8A5;" FontSize="18" Foreground="{StaticResource AccentBlue}"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Advanced problem solving math" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border CornerRadius="6" Padding="7,2" Background="{StaticResource TintGreen}" VerticalAlignment="Center">
                                            <TextBlock Text="H. math 1" FontSize="11" Foreground="{StaticResource AccentGreen}"/>
                                        </Border>
                                        <TextBlock Text="Assignment 5" Style="{StaticResource LDMuted}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource AccentPink}" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Lang.LearnDash_SubmitBeforeSample, Mode=OneWay}"
                                           FontSize="11" Foreground="{StaticResource AccentPink}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" HorizontalAlignment="Stretch" FontSize="12">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind Lang.LearnDash_View, Mode=OneWay}"/>
                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" HorizontalAlignment="Stretch" FontSize="12" Style="{ThemeResource AccentButtonStyle}">
                                    <TextBlock Text="{x:Bind Lang.LearnDash_Upload, Mode=OneWay}"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Pending quizzes -->
                    <Border Style="{StaticResource LDCard}">
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="{x:Bind Lang.LearnDash_PendingQuizzes, Mode=OneWay}"
                                           Style="{StaticResource LDCardTitle}" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Padding="11,4">
                                    <TextBlock Text="{x:Bind Lang.LearnDash_SeeAll, Mode=OneWay}"/>
                                </Button>
                            </Grid>

                            <!-- Quiz row 1 -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" Background="{StaticResource TintPurple}" VerticalAlignment="Center">
                                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE897;" FontSize="16" Foreground="{StaticResource AccentPurple}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Vector division" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Lang.LearnDash_QuizMeta, Mode=OneWay}" Style="{StaticResource LDMuted}"/>
                                </StackPanel>
                                <Button Grid.Column="2" VerticalAlignment="Center" FontSize="11" Padding="11,4">
                                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind Lang.LearnDash_Start, Mode=OneWay}"/>
                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Quiz row 2 -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" Background="{StaticResource TintPurple}" VerticalAlignment="Center">
                                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE897;" FontSize="16" Foreground="{StaticResource AccentPurple}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Vector division" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Lang.LearnDash_QuizMeta, Mode=OneWay}" Style="{StaticResource LDMuted}"/>
                                </StackPanel>
                                <Button Grid.Column="2" VerticalAlignment="Center" FontSize="11" Padding="11,4">
                                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind Lang.LearnDash_Start, Mode=OneWay}"/>
                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
