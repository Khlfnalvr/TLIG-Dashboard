<Page
    x:Class="TLIGDashboard.Views.AIPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TLIGDashboard.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- provider / model picker -->
            <RowDefinition Height="*"/>     <!-- chat history -->
            <RowDefinition Height="Auto"/>  <!-- quick suggestions -->
            <RowDefinition Height="Auto"/>  <!-- input bar -->
        </Grid.RowDefinitions>

        <!-- ── Provider / model picker (shared control) ─────────────── -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="20,8,20,8">
            <controls:AiModelPicker x:Name="ModelPicker"/>
        </Border>

        <!-- ── Chat history ─────────────────────────────────────────── -->
        <ScrollViewer x:Name="ChatScroll"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,14,20,14">
            <StackPanel x:Name="ChatPanel"
                        Spacing="10"
                        HorizontalAlignment="Center"/>
        </ScrollViewer>

        <!-- ── Quick Suggestions (above input) ───────────────────────── -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="20,10,20,10">
            <StackPanel x:Name="SuggestionPanel"
                        Spacing="8"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="SuggestionLabel"
                           Text="{x:Bind Lang.Ai_QuickSuggestion, Mode=OneWay}"
                           FontSize="11" FontWeight="SemiBold"
                           Opacity="0.6"/>
                <Grid x:Name="SuggestionGrid"
                      ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Grid.Column="0"
                            Tag="Tuning PID"
                            HorizontalAlignment="Stretch"
                            FontSize="13"
                            Click="QuickSuggestion_Click"
                            Content="{x:Bind Lang.Ai_SugTuningPid, Mode=OneWay}"/>
                    <Button Grid.Row="0" Grid.Column="1"
                            Tag="Analysis Overshoot"
                            HorizontalAlignment="Stretch"
                            FontSize="13"
                            Click="QuickSuggestion_Click"
                            Content="{x:Bind Lang.Ai_SugOvershoot, Mode=OneWay}"/>
                    <Button Grid.Row="1" Grid.Column="0"
                            Tag="Heat Exchanger Theory"
                            HorizontalAlignment="Stretch"
                            FontSize="13"
                            Click="QuickSuggestion_Click"
                            Content="{x:Bind Lang.Ai_SugHeatExchanger, Mode=OneWay}"/>
                    <Button Grid.Row="1" Grid.Column="1"
                            Tag="Troubleshooting"
                            HorizontalAlignment="Stretch"
                            FontSize="13"
                            Click="QuickSuggestion_Click"
                            Content="{x:Bind Lang.Ai_SugTroubleshooting, Mode=OneWay}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Input bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="20,12,20,12">
            <Grid x:Name="InputGrid" ColumnSpacing="8" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="ChatInput"
                         Grid.Column="0"
                         FontSize="13"
                         MinHeight="34"
                         MaxHeight="104"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Center"
                         KeyDown="ChatInput_KeyDown"/>

                <!-- Stop generation (visible while streaming) -->
                <Button x:Name="StopBtn"
                        Grid.Column="1"
                        Width="42"
                        Padding="0"
                        VerticalAlignment="Stretch"
                        Visibility="Collapsed"
                        Click="StopBtn_Click">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14" Glyph="&#xE71A;"/>
                </Button>

                <!-- Send -->
                <Button x:Name="ChatSendBtn"
                        Grid.Column="2"
                        Width="42"
                        Padding="0"
                        VerticalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="ChatSend_Click">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="15" Glyph="&#xE725;"/>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Page>
