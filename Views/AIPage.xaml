<Page
    x:Class="TLIGDashboard.Views.AIPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- top bar -->
            <RowDefinition Height="*"/>     <!-- chat history -->
            <RowDefinition Height="Auto"/>  <!-- input bar -->
        </Grid.RowDefinitions>

        <!-- ── Top bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="20,8,12,8">
            <Grid>
                <TextBlock x:Name="ModelLabel"
                           FontSize="11" FontWeight="SemiBold"
                           CharacterSpacing="60" Opacity="0.55"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="4">
                    <!-- Clear chat -->
                    <Button x:Name="ClearBtn"
                            Padding="8,5"
                            Click="ClearBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      FontSize="12" Glyph="&#xE74D;"/>
                            <TextBlock x:Name="ClearLabel" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <!-- AI Settings -->
                    <Button x:Name="SettingsBtn"
                            Padding="8,5"
                            Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      FontSize="12" Glyph="&#xE713;"/>
                            <TextBlock x:Name="SettingsLabel" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout x:Name="SettingsFlyout" Placement="Bottom">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding"         Value="16,12,16,16"/>
                                        <Setter Property="CornerRadius"    Value="{ThemeResource OverlayCornerRadius}"/>
                                        <Setter Property="BorderBrush"     Value="{ThemeResource SurfaceStrokeColorFlyoutBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="MinWidth"        Value="340"/>
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>

                                <StackPanel Width="320" Spacing="12">
                                    <!-- Server URL -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="LblApiUrl" FontSize="11" Opacity="0.7"/>
                                        <TextBox x:Name="ApiUrlBox"
                                                 FontSize="12"
                                                 PlaceholderText="https://api.deepseek.com"/>
                                    </StackPanel>

                                    <!-- API Key -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="LblApiKey" FontSize="11" Opacity="0.7"/>
                                        <PasswordBox x:Name="ApiKeyBox"
                                                     FontSize="12"
                                                     PlaceholderText="sk-..."/>
                                    </StackPanel>

                                    <!-- Model -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="LblModel" FontSize="11" Opacity="0.7"/>
                                        <TextBox x:Name="ModelBox"
                                                 FontSize="12"
                                                 PlaceholderText="deepseek-chat"/>
                                    </StackPanel>

                                    <!-- System Prompt -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="LblSysPrompt" FontSize="11" Opacity="0.7"/>
                                        <TextBox x:Name="SysPromptBox"
                                                 FontSize="12"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MaxHeight="100"/>
                                    </StackPanel>

                                    <!-- Save -->
                                    <Button x:Name="SaveSettingsBtn"
                                            HorizontalAlignment="Stretch"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Click="SaveSettings_Click"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Chat history ─────────────────────────────────────────── -->
        <ScrollViewer x:Name="ChatScroll"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,14,20,14">
            <StackPanel x:Name="ChatPanel"
                        Spacing="10"
                        HorizontalAlignment="Center"/>
        </ScrollViewer>

        <!-- ── Input bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="20,12,20,12">
            <Grid x:Name="InputGrid" ColumnSpacing="8" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="ChatInput"
                         Grid.Column="0"
                         FontSize="13"
                         MaxHeight="120"
                         VerticalAlignment="Center"
                         KeyDown="ChatInput_KeyDown"/>

                <!-- Stop generation (visible while streaming) -->
                <Button x:Name="StopBtn"
                        Grid.Column="1"
                        Width="42" Height="42"
                        Padding="0"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Click="StopBtn_Click">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14" Glyph="&#xE71A;"/>
                </Button>

                <!-- Send -->
                <Button x:Name="ChatSendBtn"
                        Grid.Column="2"
                        Width="42" Height="42"
                        Padding="0"
                        VerticalAlignment="Bottom"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="ChatSend_Click">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="15" Glyph="&#xE725;"/>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Page>
