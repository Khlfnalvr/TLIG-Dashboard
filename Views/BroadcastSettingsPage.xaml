<Page
    x:Class="TLIGDashboard.Views.BroadcastSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!--
            Masonry layout: three independent StackPanel columns so card heights
            never create empty gaps beside shorter neighbours. On narrow windows
            everything reflows into one column.
        -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1180"/>
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="GCol1.Width" Value="0"/>
                        <Setter Target="GCol2.Width" Value="0"/>
                        <Setter Target="Col1.(Grid.Column)" Value="0"/>
                        <Setter Target="Col1.(Grid.Row)" Value="1"/>
                        <Setter Target="Col2.(Grid.Column)" Value="0"/>
                        <Setter Target="Col2.(Grid.Row)" Value="2"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1700" HorizontalAlignment="Stretch" Spacing="16">

                <!-- ── Header ── -->
                <StackPanel Spacing="2">
                    <TextBlock Text="{x:Bind Lang.Nav_Settings, Mode=OneWay}"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind Lang.Settings_Subtitle, Mode=OneWay}"
                               FontSize="12" Opacity="0.65" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ── Three independent card columns ── -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="GCol0" Width="*"/>
                        <ColumnDefinition x:Name="GCol1" Width="*"/>
                        <ColumnDefinition x:Name="GCol2" Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ════════════ COL 0 — Share server + Cloudflare Tunnel ════════════ -->
                    <StackPanel x:Name="Col0" Grid.Column="0" Grid.Row="0" Spacing="16">

                        <!-- ══ SERVER / BROADCAST CARD ══ -->
                        <Border x:Name="CardShare" Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind Lang.Bcast_ServerSection, Mode=OneWay}"
                                           Style="{StaticResource CardTitleStyle}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Share_Port, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="PortBox" FontSize="13" Width="160"
                                             HorizontalAlignment="Left" Text="8088"/>
                                </StackPanel>

                                <CheckBox x:Name="ShareCameraCheck" IsChecked="True"
                                          Content="{x:Bind Lang.Share_ShareCamera, Mode=OneWay}"/>
                                <CheckBox x:Name="ShareHmiCheck" IsChecked="True"
                                          Content="{x:Bind Lang.Share_ShareHmi, Mode=OneWay}"/>

                                <Button x:Name="StartBtn"
                                        HorizontalAlignment="Stretch"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="StartBtn_Click"/>

                                <TextBlock x:Name="ServerStatusText"
                                           FontSize="12" Opacity="0.75" TextWrapping="Wrap"/>

                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="LocalAddrText"
                                               FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PublicAddrText"
                                               FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                               Visibility="Collapsed"/>
                                </StackPanel>

                                <TextBlock Text="{x:Bind Lang.Share_AuthHint, Mode=OneWay}"
                                           FontSize="11" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- ══ CLOUDFLARE TUNNEL CARD ══ -->
                        <Border x:Name="CardTunnel" Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                  FontSize="14" Glyph="&#xE774;" Opacity="0.8"/>
                                        <TextBlock Text="{x:Bind Lang.Tunnel_Title, Mode=OneWay}"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button x:Name="TunnelToggleBtn"
                                            HorizontalAlignment="Right"
                                            Click="TunnelToggle_Click"/>
                                </Grid>

                                <TextBlock Text="{x:Bind Lang.Bcast_TunnelDesc, Mode=OneWay}"
                                           FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>

                                <!-- ── Custom domain (named tunnel) ── -->
                                <StackPanel Spacing="8">
                                    <CheckBox x:Name="TunnelCustomDomainCheck"
                                              Content="{x:Bind Lang.Tunnel_UseCustomDomain, Mode=OneWay}"
                                              Click="TunnelCustomDomainCheck_Click"/>

                                    <StackPanel x:Name="TunnelCustomDomainPanel" Spacing="10" Visibility="Collapsed">
                                        <TextBlock Text="{x:Bind Lang.Tunnel_CustomDomainDesc, Mode=OneWay}"
                                                   FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{x:Bind Lang.Tunnel_DomainLabel, Mode=OneWay}"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TunnelDomainBox" FontSize="13"
                                                     PlaceholderText="{x:Bind Lang.Tunnel_DomainHint, Mode=OneWay}"/>
                                        </StackPanel>

                                        <Button x:Name="TunnelLoginBtn"
                                                HorizontalAlignment="Stretch"
                                                Click="TunnelLogin_Click"
                                                Content="{x:Bind Lang.Tunnel_Login, Mode=OneWay}"/>

                                        <TextBlock x:Name="TunnelLoginStatus"
                                                   FontSize="11" Opacity="0.75" TextWrapping="Wrap"/>

                                        <TextBlock x:Name="TunnelLoginUrlText"
                                                   FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                                   IsTextSelectionEnabled="True"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel x:Name="TunnelDownloadPanel" Spacing="8" Visibility="Collapsed">
                                    <TextBlock Text="{x:Bind Lang.Tunnel_NotFound, Mode=OneWay}"
                                               FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                                    <Button x:Name="TunnelDownloadBtn"
                                            HorizontalAlignment="Stretch"
                                            Click="TunnelDownload_Click"
                                            Content="{x:Bind Lang.Tunnel_Download, Mode=OneWay}"/>
                                    <ProgressBar x:Name="TunnelDownloadBar" Minimum="0" Maximum="1"
                                                 HorizontalAlignment="Stretch"
                                                 Visibility="Collapsed"/>
                                </StackPanel>

                                <TextBlock x:Name="TunnelStatusText"
                                           FontSize="12" Opacity="0.75" TextWrapping="Wrap"/>

                                <Border x:Name="TunnelUrlRow"
                                        Visibility="Collapsed"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="10,8">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TunnelUrlText"
                                                   Grid.Column="0"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   IsTextSelectionEnabled="True"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center">
                                            <ToolTipService.ToolTip>
                                                <ToolTip x:Name="TunnelUrlTooltip"/>
                                            </ToolTipService.ToolTip>
                                        </TextBlock>
                                        <Button Grid.Column="1"
                                                x:Name="TunnelCopyBtn"
                                                Click="TunnelCopy_Click"
                                                Content="{x:Bind Lang.Tunnel_CopyUrl, Mode=OneWay}"/>
                                    </Grid>
                                </Border>

                                <TextBlock x:Name="TunnelShareHintText"
                                           FontSize="11" Opacity="0.55" TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           Text="{x:Bind Lang.Tunnel_ShareHint, Mode=OneWay}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════════════ COL 1 — AI Settings ════════════ -->
                    <StackPanel x:Name="Col1" Grid.Column="1" Grid.Row="0" Spacing="16">

                        <!-- ══ AI API CARD ══ -->
                        <Border x:Name="CardAi" Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind Lang.Ai_Settings, Mode=OneWay}"
                                           Style="{StaticResource CardTitleStyle}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Ai_ApiUrl, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="AiApiUrlBox" FontSize="13"
                                             PlaceholderText="https://api.deepseek.com"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Ai_ApiKey, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <PasswordBox x:Name="AiApiKeyBox" FontSize="13" PlaceholderText="sk-..."/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Ai_Model, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="AiModelBox" FontSize="13"
                                             PlaceholderText="deepseek-chat"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Ai_SystemPrompt, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="AiSysPromptBox" FontSize="13"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72"/>
                                </StackPanel>

                                <Button x:Name="AiSaveBtn" HorizontalAlignment="Stretch"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="AiSaveBtn_Click"
                                        Content="{x:Bind Lang.Ai_SaveSettings, Mode=OneWay}"/>

                                <TextBlock x:Name="AiStatusText" FontSize="12" Opacity="0.75" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ════════════ COL 2 — OPC UA Connection ════════════ -->
                    <StackPanel x:Name="Col2" Grid.Column="2" Grid.Row="0" Spacing="16">

                        <!-- ══ OPC UA CARD ══ -->
                        <Border x:Name="CardOpc" Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind Lang.Ui_OpcUaConnection, Mode=OneWay}"
                                           Style="{StaticResource CardTitleStyle}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Ui_OpcUaEndpoint, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="OpcEndpointBox" FontSize="13"
                                             PlaceholderText="opc.tcp://host:4840"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Ui_OpcUaSecurity, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="OpcSecurityCombo" FontSize="13"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem x:Name="OpcSecNone"    Tag="None"/>
                                        <ComboBoxItem x:Name="OpcSecSign"    Tag="Sign"/>
                                        <ComboBoxItem x:Name="OpcSecSignEnc" Tag="SignAndEncrypt"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Lang.Ui_OpcUaAuth, Mode=OneWay}"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="OpcAuthCombo" FontSize="13"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OpcAuthCombo_SelectionChanged">
                                        <ComboBoxItem x:Name="OpcAuthAnon" Tag="Anonymous"/>
                                        <ComboBoxItem x:Name="OpcAuthUser" Tag="Username"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel x:Name="OpcCredPanel" Spacing="6" Visibility="Collapsed">
                                    <TextBox x:Name="OpcUsernameBox" FontSize="13"
                                             PlaceholderText="{x:Bind Lang.Ui_OpcUaUsername, Mode=OneWay}"/>
                                    <PasswordBox x:Name="OpcPasswordBox" FontSize="13"
                                                 PlaceholderText="{x:Bind Lang.Ui_OpcUaPassword, Mode=OneWay}"/>
                                </StackPanel>

                                <Button x:Name="OpcConnectBtn" HorizontalAlignment="Stretch"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="OpcConnectBtn_Click"/>

                                <TextBlock x:Name="OpcStatusText" FontSize="12" Opacity="0.75" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
