<Page
    x:Class="TLIGDashboard.Views.TaskDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentGreen"  Color="#FF10B981"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FFF59E0B"/>
        <SolidColorBrush x:Key="TintGreen"    Color="#2610B981"/>
        <SolidColorBrush x:Key="TintOrange"   Color="#26F59E0B"/>

        <Style x:Key="DetailCard" TargetType="Border">
            <Setter Property="Background"      Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="16"/>
        </Style>

        <Style x:Key="DetailHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity"    Value="0.55"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20,16,20,20">
        <StackPanel Spacing="14" MaxWidth="820" HorizontalAlignment="Left">

            <Button Click="Back_Click" Padding="10,5" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="12"/>
                    <TextBlock Text="{x:Bind Lang.LearnDash_Back, Mode=OneWay}"/>
                </StackPanel>
            </Button>

            <!-- Header: title + created-by + status pill -->
            <StackPanel x:Name="ContentRoot" Spacing="14">
                <Grid>
                    <StackPanel Spacing="3">
                        <TextBlock x:Name="TitleText" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="CreatedByText" FontSize="12" Opacity="0.55"/>
                    </StackPanel>
                    <Border x:Name="StatusBorder" HorizontalAlignment="Right" VerticalAlignment="Top"
                            CornerRadius="10" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon x:Name="StatusIcon" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="12"/>
                            <TextBlock x:Name="StatusText" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Objective -->
                <Border Style="{StaticResource DetailCard}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind Lang.LearnDash_ObjectiveHeader, Mode=OneWay}" Style="{StaticResource DetailHeader}"/>
                        <TextBlock x:Name="ObjectiveText" FontSize="14" TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                </Border>

                <!-- Target -->
                <Border Style="{StaticResource DetailCard}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{x:Bind Lang.LearnDash_TargetHeader, Mode=OneWay}" Style="{StaticResource DetailHeader}"/>
                        <TextBlock x:Name="TargetText" FontSize="14" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="MarkBtn" Click="Mark_Click" Style="{ThemeResource AccentButtonStyle}"/>
                    <Button x:Name="EditBtn" Click="Edit_Click" Visibility="Collapsed"
                            Content="{x:Bind Lang.LearnDash_Edit, Mode=OneWay}"/>
                    <Button x:Name="DeleteBtn" Click="Delete_Click" Visibility="Collapsed"
                            Content="{x:Bind Lang.LearnDash_Delete, Mode=OneWay}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock x:Name="NotFoundText" Text="{x:Bind Lang.LearnDash_TaskNotFound, Mode=OneWay}"
                       FontSize="14" Opacity="0.7" Visibility="Collapsed" Margin="2,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
