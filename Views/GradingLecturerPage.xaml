<!-- Views/GradingLecturerPage.xaml -->
<!-- Tambahkan file ini ke folder Views/ di project TLIG-Dashboard -->
<!-- Akses dari navigasi: role = Dosen -->

<Page
    x:Class="TLIGDashboard.Views.GradingLecturerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TLIGDashboard.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Padding="28,20,28,16"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Manajemen Penilaian"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Monitor dan kelola seluruh penilaian mahasiswa"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6"/>
                </StackPanel>

                <ComboBox x:Name="AssignmentCombo"
                          Grid.Column="1"
                          MinWidth="260"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"
                          Header="Pilih Tugas"
                          SelectionChanged="AssignmentCombo_SelectionChanged"/>

                <Button x:Name="ExportBtn"
                        Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,1"
                        Click="Export_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Glyph="&#xE78C;" FontSize="14"/>
                        <TextBlock Text="Ekspor"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Body ────────────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="28,20,28,28">
            <StackPanel Spacing="20">

                <!-- ── Stats Bar ─────────────────────────────────────────── -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Total Mahasiswa"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatTotalStudents" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Sudah Dinilai Dosen"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatGraded" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Rata-rata Kelas"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatClassAvg" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Peer Selesai"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock x:Name="StatPeerDone" Text="—"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Pivot Utama ────────────────────────────────────────── -->
                <Pivot x:Name="MainPivot" SelectionChanged="MainPivot_SelectionChanged">

                    <!-- ─── Tab 1: Rekap Nilai Gabungan ─────────────────── -->
                    <PivotItem Header="Rekap Nilai">
                        <StackPanel Spacing="16" Margin="0,16,0,0">
                            <Grid>
                                <TextBlock Text="Ringkasan Nilai Akhir Mahasiswa"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <Button Content="Segarkan" Click="RefreshSummary_Click"/>
                                    <Button Content="Nilai Semua"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Click="GradeAll_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Tabel ringkasan -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8">
                                <!-- Header tabel -->
                                <StackPanel>
                                    <Grid Padding="16,12" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Mahasiswa" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="Kelompok" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        <TextBlock Grid.Column="2" Text="Peer" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Sistem" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Dosen" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="Final" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="Grade" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="7" Text="Aksi" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                    <ItemsRepeater x:Name="SummaryRepeater">
                                        <ItemsRepeater.Layout>
                                            <StackLayout/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="16,12"
                                                      BorderThickness="0,0,0,1"
                                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StudentName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                        <TextBlock Text="{Binding StudentId}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding GroupName}"
                                                               Style="{ThemeResource BodyTextBlockStyle}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding PeerScoreStr}"
                                                               Style="{ThemeResource BodyTextBlockStyle}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding SystemScoreStr}"
                                                               Style="{ThemeResource BodyTextBlockStyle}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding LecturerScoreStr}"
                                                               Style="{ThemeResource BodyTextBlockStyle}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding FinalScoreStr}"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="6"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            Background="{Binding GradeBadgeColor}"
                                                            CornerRadius="4" Padding="8,3">
                                                        <TextBlock Text="{Binding LetterGrade}"
                                                                   FontWeight="Bold"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <Button Grid.Column="7"
                                                            Tag="{Binding StudentId}"
                                                            Content="Nilai"
                                                            HorizontalAlignment="Center"
                                                            Style="{ThemeResource AccentButtonStyle}"
                                                            FontSize="12"
                                                            Padding="12,4"
                                                            Click="GradeStudent_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </PivotItem>

                    <!-- ─── Tab 2: Penilaian Peer ─────────────────────── -->
                    <PivotItem Header="Penilaian Peer">
                        <StackPanel Spacing="16" Margin="0,16,0,0">
                            <TextBlock Text="Penilaian Mahasiswa ke Mahasiswa"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <ItemsRepeater x:Name="AllPeerRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="10"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="16,14">
                                            <Grid ColumnSpacing="16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding EvaluatorName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                  Glyph="&#xE72A;" FontSize="12" Opacity="0.5"/>
                                                        <TextBlock Text="{Binding EvaluateeName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Comment}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"
                                                               MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding EvaluatedAtStr}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.4"/>
                                                </StackPanel>

                                                <!-- Sub-scores -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding SubScoresStr}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                                </StackPanel>

                                                <Border Grid.Column="3"
                                                        CornerRadius="6"
                                                        Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                        Padding="12,6"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ScoreStr}"
                                                               Style="{ThemeResource SubtitleTextBlockStyle}"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </PivotItem>

                    <!-- ─── Tab 3: Penilaian Sistem ───────────────────── -->
                    <PivotItem Header="Penilaian Sistem">
                        <StackPanel Spacing="16" Margin="0,16,0,0">
                            <TextBlock Text="Skor Otomatis Sistem per Mahasiswa"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <ItemsRepeater x:Name="SystemEvalRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="10"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="20,16">
                                            <Grid ColumnSpacing="20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StudentName}"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                    <TextBlock Text="{Binding StudentId}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"/>
                                                </StackPanel>

                                                <!-- Metric chips -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                                            FlowDirection="LeftToRight" VerticalAlignment="Center">
                                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                            CornerRadius="4" Padding="8,4">
                                                        <TextBlock Text="{Binding CommitStr}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                    </Border>
                                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                            CornerRadius="4" Padding="8,4">
                                                        <TextBlock Text="{Binding FileStr}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                    </Border>
                                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                            CornerRadius="4" Padding="8,4">
                                                        <TextBlock Text="{Binding TaskStr}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                                                    </Border>
                                                    <Border CornerRadius="4" Padding="8,4"
                                                            Background="{Binding OnTimeBg}">
                                                        <TextBlock Text="{Binding OnTimeStr}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding OnTimeFg}"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Score badge -->
                                                <Border Grid.Column="2"
                                                        CornerRadius="6"
                                                        Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                        Padding="12,6" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ScoreStr}"
                                                               Style="{ThemeResource SubtitleTextBlockStyle}"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </PivotItem>

                    <!-- ─── Tab 4: Aktivitas Kelompok ─────────────────── -->
                    <PivotItem Header="Aktivitas Kelompok">
                        <StackPanel Spacing="16" Margin="0,16,0,0">
                            <Grid>
                                <TextBlock Text="Recent Activities — Semua Mahasiswa"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Content="Segarkan"
                                        Click="RefreshActivities_Click"/>
                            </Grid>

                            <ItemsRepeater x:Name="LecActivitiesRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="8"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1" CornerRadius="7" Padding="14,12">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="36" Height="36" CornerRadius="18"
                                                        Background="{ThemeResource AccentFillColorTertiaryBrush}">
                                                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                              Glyph="{Binding ActivityIcon}" FontSize="16"
                                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding StudentName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                CornerRadius="3" Padding="6,2">
                                                            <TextBlock Text="{Binding ActivityType}"
                                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        CornerRadius="4" Padding="8,3"
                                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding AutoScoreStr}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TimeAgo}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Opacity="0.4" VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </PivotItem>

                </Pivot>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Dialog Nilai Dosen ──────────────────────────────────────────── -->
        <ContentDialog x:Name="GradeDialog"
                       Title="Beri Nilai Mahasiswa"
                       PrimaryButtonText="Simpan Nilai"
                       CloseButtonText="Batal"
                       DefaultButton="Primary"
                       PrimaryButtonClick="GradeDialog_PrimaryButtonClick">
            <StackPanel Width="400" Spacing="16">
                <TextBlock x:Name="GradeDialogStudentName"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           FontWeight="SemiBold"/>

                <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}"/>

                <Grid ColumnSpacing="16" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                        <TextBlock Text="Nilai Presentasi" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                        <NumberBox x:Name="NbPresentation" Minimum="0" Maximum="100" Value="75"
                                   SpinButtonPlacementMode="Inline" SmallChange="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                        <TextBlock Text="Nilai Laporan" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                        <NumberBox x:Name="NbReport" Minimum="0" Maximum="100" Value="75"
                                   SpinButtonPlacementMode="Inline" SmallChange="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                        <TextBlock Text="Nilai Implementasi" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                        <NumberBox x:Name="NbImplementation" Minimum="0" Maximum="100" Value="75"
                                   SpinButtonPlacementMode="Inline" SmallChange="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                        <TextBlock Text="Nilai Defence / Ujian" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                        <NumberBox x:Name="NbDefense" Minimum="0" Maximum="100" Value="75"
                                   SpinButtonPlacementMode="Inline" SmallChange="1"/>
                    </StackPanel>
                </Grid>

                <TextBox x:Name="FeedbackBox"
                         Header="Feedback untuk Mahasiswa"
                         PlaceholderText="Tuliskan catatan atau masukan..."
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="70"
                         MaxLength="1000"/>

                <CheckBox x:Name="FinalizeCheck"
                          Content="Finalisasi nilai (tidak dapat diubah mahasiswa)"/>
            </StackPanel>
        </ContentDialog>

    </Grid>
</Page>
