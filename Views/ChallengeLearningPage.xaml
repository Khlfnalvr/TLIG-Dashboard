<Page
    x:Class="TLIGDashboard.Views.ChallengeLearningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>

        <!-- ── Colour tokens ──────────────────────────────────────── -->
        <SolidColorBrush x:Key="CL_Purple"  Color="#7c3aed"/>
        <SolidColorBrush x:Key="CL_Orange"  Color="#f59e0b"/>
        <SolidColorBrush x:Key="CL_Green"   Color="#10b981"/>
        <SolidColorBrush x:Key="CL_Red"     Color="#ef4444"/>
        <SolidColorBrush x:Key="CL_Surface" Color="#1e1e2e"/>
        <SolidColorBrush x:Key="CL_CardBg"  Color="#252535"/>
        <SolidColorBrush x:Key="CL_Border"  Color="#2d2d3e"/>
        <SolidColorBrush x:Key="CL_Text"    Color="#e0e0f0"/>
        <SolidColorBrush x:Key="CL_Muted"   Color="#8080a0"/>

        <!-- ── Shared styles ──────────────────────────────────────── -->
        <Style x:Key="CL_Card" TargetType="Border">
            <Setter Property="Background"      Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"     Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="14"/>
        </Style>
        <Style x:Key="CL_Label" TargetType="TextBlock">
            <Setter Property="FontSize"  Value="11"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>
        <Style x:Key="CL_SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity"    Value="0.6"/>
            <Setter Property="CharacterSpacing" Value="80"/>
        </Style>

    </Page.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         ROOT: Left sidebar + Right content
         ═══════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════
             LEFT — Challenge List
             ══════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="14,12,14,10"
                    BorderBrush="#2d2d3e" BorderThickness="0,0,0,1">
                <StackPanel Spacing="2">
                    <TextBlock Text="Challenge Learning"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#e0e0f0"/>
                    <TextBlock x:Name="ModeLabel"
                               FontSize="10" Foreground="#7c3aed"/>
                </StackPanel>
            </Border>

            <!-- Action bar (admin: + New | student: hidden) -->
            <Border Grid.Row="1" Padding="12,8" BorderBrush="#2d2d3e" BorderThickness="0,0,0,1">
                <Grid>
                    <Button x:Name="NewChallengeBtn"
                            Content="+ Buat Challenge"
                            Background="#7c3aed"
                            Foreground="White"
                            FontSize="11" FontWeight="SemiBold"
                            CornerRadius="6"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            Click="NewChallengeBtn_Click"/>
                    <!-- Student: filter hint -->
                    <TextBlock x:Name="StudentListHint"
                               Text="Challenge aktif untukmu"
                               Style="{StaticResource CL_Label}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- Challenge ListView -->
            <ListView x:Name="ChallengeList"
                      Grid.Row="2"
                      SelectionChanged="ChallengeList_SelectionChanged"
                      SelectionMode="Single"
                      Background="Transparent"
                      Padding="8">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding"         Value="0"/>
                        <Setter Property="Margin"          Value="0,3"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="CornerRadius"    Value="8"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,8" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock x:Name="ItemTitle"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#e0e0f0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="ItemMeta"
                                               FontSize="10" Foreground="#8080a0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Border x:Name="StatusBadge"
                                        Grid.Column="1"
                                        CornerRadius="4" Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="StatusText"
                                               FontSize="9" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Divider -->
        <Border Grid.Column="1" Background="#2d2d3e"/>

        <!-- ══════════════════════════════════
             RIGHT — Detail / Form
             ══════════════════════════════════ -->
        <Grid Grid.Column="2" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

            <!-- ── Empty state ── -->
            <StackPanel x:Name="EmptyState"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="10">
                <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                          Glyph="&#xE8F9;" FontSize="48"
                          Foreground="#2d2d3e" HorizontalAlignment="Center"/>
                <TextBlock x:Name="EmptyHint"
                           FontSize="13" Foreground="#8080a0"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>

            <!-- ── ADMIN: Create / Edit Form ── -->
            <ScrollViewer x:Name="AdminFormPanel"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <StackPanel Spacing="12">

                    <TextBlock x:Name="FormTitleLabel"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#e0e0f0"/>

                    <!-- Title -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="JUDUL CHALLENGE" Style="{StaticResource CL_SectionHeader}"/>
                        <TextBox x:Name="FormTitleBox"
                                 PlaceholderText="Judul challenge..."
                                 FontSize="12" CornerRadius="6"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="DESKRIPSI" Style="{StaticResource CL_SectionHeader}"/>
                        <TextBox x:Name="FormDescBox"
                                 PlaceholderText="Deskripsi singkat..."
                                 FontSize="12" AcceptsReturn="True"
                                 TextWrapping="Wrap" Height="72"
                                 CornerRadius="6"/>
                    </StackPanel>

                    <!-- Instructions -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="INSTRUKSI / PERTANYAAN" Style="{StaticResource CL_SectionHeader}"/>
                        <TextBox x:Name="FormInstrBox"
                                 PlaceholderText="Langkah-langkah atau pertanyaan untuk mahasiswa..."
                                 FontSize="12" AcceptsReturn="True"
                                 TextWrapping="Wrap" Height="100"
                                 CornerRadius="6"/>
                    </StackPanel>

                    <!-- Target System + Deadline (row) -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="TARGET SISTEM" Style="{StaticResource CL_SectionHeader}"/>
                            <ComboBox x:Name="FormSystemCombo"
                                      HorizontalAlignment="Stretch"
                                      FontSize="12" CornerRadius="6">
                                <ComboBoxItem Content="Flow"        Tag="Flow"/>
                                <ComboBoxItem Content="Level"       Tag="Level"/>
                                <ComboBoxItem Content="Temperature" Tag="Temperature"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="DEADLINE" Style="{StaticResource CL_SectionHeader}"/>
                            <CalendarDatePicker x:Name="FormDeadlinePicker"
                                                PlaceholderText="Pilih tanggal..."
                                                HorizontalAlignment="Stretch"
                                                FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── TASKS ── -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock Text="TASKS &amp; TARGET METRICS"
                                           Style="{StaticResource CL_SectionHeader}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="AddTaskBtn"
                                        Content="+ Tambah Task"
                                        FontSize="11" CornerRadius="6"
                                        Padding="8,4"
                                        HorizontalAlignment="Right"
                                        Click="AddTaskBtn_Click"/>
                            </Grid>
                            <StackPanel x:Name="TaskListPanel" Spacing="8"/>
                            <TextBlock x:Name="NoTasksHint"
                                       Text="Belum ada task. Klik '+ Tambah Task'."
                                       Style="{StaticResource CL_Label}"
                                       Margin="0,4"/>
                        </StackPanel>
                    </Border>

                    <!-- ── GRADING WEIGHTS ── -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock Text="BOBOT PENILAIAN"
                                           Style="{StaticResource CL_SectionHeader}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="WeightTotalText"
                                           FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Dosen (%)" Style="{StaticResource CL_Label}"/>
                                    <NumberBox x:Name="WeightDosenBox"
                                               Minimum="0" Maximum="100"
                                               SmallChange="5" FontSize="12"
                                               SpinButtonPlacementMode="Compact"
                                               ValueChanged="WeightBox_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="AI (%)" Style="{StaticResource CL_Label}"/>
                                    <NumberBox x:Name="WeightAiBox"
                                               Minimum="0" Maximum="100"
                                               SmallChange="5" FontSize="12"
                                               SpinButtonPlacementMode="Compact"
                                               ValueChanged="WeightBox_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Peer (%)" Style="{StaticResource CL_Label}"/>
                                    <NumberBox x:Name="WeightPeerBox"
                                               Minimum="0" Maximum="100"
                                               SmallChange="5" FontSize="12"
                                               SpinButtonPlacementMode="Compact"
                                               ValueChanged="WeightBox_Changed"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Status toggle -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="STATUS" Style="{StaticResource CL_SectionHeader}"/>
                        <ComboBox x:Name="FormStatusCombo" FontSize="12" CornerRadius="6">
                            <ComboBoxItem Content="Draft"  Tag="Draft"/>
                            <ComboBoxItem Content="Active" Tag="Active"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Save / Cancel -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button x:Name="SaveChallengeBtn"
                                Content="Simpan Challenge"
                                Background="#7c3aed" Foreground="White"
                                FontSize="12" FontWeight="SemiBold"
                                CornerRadius="6" Padding="14,8"
                                Click="SaveChallengeBtn_Click"/>
                        <Button x:Name="CancelFormBtn"
                                Content="Batal"
                                FontSize="12" CornerRadius="6" Padding="14,8"
                                Click="CancelFormBtn_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="FormStatusText"
                               FontSize="11" Margin="0,2"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ── ADMIN: Challenge Detail + Submissions ── -->
            <ScrollViewer x:Name="AdminDetailPanel"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <StackPanel Spacing="14">

                    <!-- Challenge header -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="DetailTitle"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="#e0e0f0" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DetailMeta"
                                       FontSize="11" Foreground="#8080a0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Top">
                            <Button x:Name="EditChallengeBtn"
                                    Content="Edit"
                                    FontSize="11" CornerRadius="6" Padding="10,5"
                                    Click="EditChallengeBtn_Click"/>
                            <Button x:Name="PublishBtn"
                                    Content="Publish"
                                    Background="#10b981" Foreground="White"
                                    FontSize="11" FontWeight="SemiBold"
                                    CornerRadius="6" Padding="10,5"
                                    Click="PublishBtn_Click"/>
                            <Button x:Name="CloseBtn"
                                    Content="Tutup"
                                    Background="#ef4444" Foreground="White"
                                    FontSize="11" FontWeight="SemiBold"
                                    CornerRadius="6" Padding="10,5"
                                    Click="CloseBtn_Click"/>
                            <Button x:Name="DeleteChallengeBtn"
                                    Content="Hapus"
                                    FontSize="11" CornerRadius="6" Padding="10,5"
                                    Click="DeleteChallengeBtn_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Tasks summary (admin) -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="TASKS" Style="{StaticResource CL_SectionHeader}"/>
                            <StackPanel x:Name="AdminTaskSummary" Spacing="6"/>
                        </StackPanel>
                    </Border>

                    <!-- Daftar Mahasiswa -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="DAFTAR MAHASISWA"
                                       Style="{StaticResource CL_SectionHeader}"/>
                            <StackPanel x:Name="StudentListRows" Spacing="6"/>
                            <TextBlock x:Name="NoStudentText"
                                       Text="Belum ada mahasiswa yang submit."
                                       Style="{StaticResource CL_Label}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Student detail + form penilaian (tersembunyi) -->
                    <Border x:Name="StudentDetailCard" Style="{StaticResource CL_Card}"
                            Visibility="Collapsed">
                        <StackPanel Spacing="12">

                            <!-- Header: nama mahasiswa + tombol kembali -->
                            <Grid>
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="SelectedStudentName"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#e0e0f0"/>
                                    <TextBlock x:Name="SelectedStudentMeta"
                                               Style="{StaticResource CL_Label}"/>
                                </StackPanel>
                                <Button x:Name="BackToStudentListBtn"
                                        Content="← Kembali"
                                        HorizontalAlignment="Right"
                                        FontSize="11" CornerRadius="6" Padding="8,4"
                                        Click="BackToStudentListBtn_Click"/>
                            </Grid>

                            <!-- Aktivitas mahasiswa -->
                            <TextBlock Text="AKTIVITAS MAHASISWA"
                                       Style="{StaticResource CL_SectionHeader}"/>
                            <StackPanel x:Name="SelectedStudentActivity" Spacing="4"/>
                            <TextBlock x:Name="NoSelectedStudentActivity"
                                       Text="Belum ada aktivitas."
                                       Style="{StaticResource CL_Label}"
                                       HorizontalAlignment="Center"/>

                            <Rectangle Height="1" Fill="#2d2d3e"
                                       Opacity="0.5" Margin="0,4,0,4"/>

                            <!-- Form penilaian dosen -->
                            <TextBlock Text="FORM PENILAIAN DOSEN"
                                       Style="{StaticResource CL_SectionHeader}"/>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4" MinWidth="140">
                                    <TextBlock Text="Nilai (0–100)"
                                               Style="{StaticResource CL_Label}"/>
                                    <NumberBox x:Name="GradeScoreBox"
                                               Minimum="0" Maximum="100" Value="0"
                                               FontSize="12" CornerRadius="6"
                                               SpinButtonPlacementMode="Compact"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Catatan / Feedback"
                                               Style="{StaticResource CL_Label}"/>
                                    <TextBox x:Name="GradeFeedbackBox"
                                             PlaceholderText="Tulis catatan untuk mahasiswa..."
                                             FontSize="12" CornerRadius="6"
                                             AcceptsReturn="True" Height="64"
                                             TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="SaveGradeBtn"
                                        Content="Simpan Nilai"
                                        Background="#7c3aed" Foreground="White"
                                        FontSize="12" FontWeight="SemiBold"
                                        CornerRadius="6" Padding="14,8"
                                        Click="SaveGradeBtn_Click"/>
                                <TextBlock x:Name="GradeSaveStatus"
                                           Style="{StaticResource CL_Label}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ══════════════════════════════════════════════════════
                 STUDENT VIEW
                 ══════════════════════════════════════════════════════ -->

            <!-- Student: hint when no challenge selected -->
            <StackPanel x:Name="StudentOverviewPanel"
                        Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="8" Padding="24">
                <FontIcon Glyph="&#xE82D;" FontSize="32"
                          Foreground="#7c3aed" HorizontalAlignment="Center"
                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                <TextBlock Text="Pilih challenge di kiri untuk melihat detail dan submit jawabanmu."
                           Style="{StaticResource CL_Label}"
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Student: Challenge detail + submit -->
            <ScrollViewer x:Name="StudentDetailPanel"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <StackPanel Spacing="14">

                    <!-- Title + system badge -->
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock x:Name="StDetailTitle"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="#e0e0f0" TextWrapping="Wrap"/>
                            <Border x:Name="StSystemBadge"
                                    Background="#2d2d3e" CornerRadius="5"
                                    Padding="8,3" VerticalAlignment="Center">
                                <TextBlock x:Name="StSystemText"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#7c3aed"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="StDetailMeta"
                                   FontSize="11" Foreground="#8080a0"/>
                    </StackPanel>

                    <!-- Description -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="DESKRIPSI" Style="{StaticResource CL_SectionHeader}"/>
                            <TextBlock x:Name="StDetailDesc"
                                       FontSize="12" Foreground="#c0c0d8"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <!-- Instructions -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="INSTRUKSI" Style="{StaticResource CL_SectionHeader}"/>
                            <TextBlock x:Name="StDetailInstr"
                                       FontSize="12" Foreground="#c0c0d8"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <!-- Tasks with live metrics -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock Text="TASKS &amp; TARGET METRICS"
                                           Style="{StaticResource CL_SectionHeader}"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="RefreshMetricsBtn"
                                        Content="↻ Refresh Metrik"
                                        FontSize="10" CornerRadius="5"
                                        Padding="8,3"
                                        HorizontalAlignment="Right"
                                        Click="RefreshMetricsBtn_Click"/>
                            </Grid>
                            <StackPanel x:Name="StudentTaskList" Spacing="8"/>
                        </StackPanel>
                    </Border>

                    <!-- My activity log -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="AKTIVITAS SAYA" Style="{StaticResource CL_SectionHeader}"/>
                            <StackPanel x:Name="MyActivityList" Spacing="4"/>
                            <TextBlock x:Name="NoMyActivityText"
                                       Text="Belum ada aktivitas untuk challenge ini."
                                       Style="{StaticResource CL_Label}"
                                       Margin="0,4" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Submit section -->
                    <Border Style="{StaticResource CL_Card}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="SUBMIT JAWABAN" Style="{StaticResource CL_SectionHeader}"/>
                            <TextBox x:Name="SubmitTextBox"
                                     PlaceholderText="Tulis jawaban, penjelasan, atau parameter PID yang kamu gunakan..."
                                     FontSize="12" AcceptsReturn="True"
                                     TextWrapping="Wrap" Height="100"
                                     CornerRadius="6"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="SubmitBtn"
                                        Content="Kirim Jawaban"
                                        Background="#7c3aed" Foreground="White"
                                        FontSize="12" FontWeight="SemiBold"
                                        CornerRadius="6" Padding="14,8"
                                        Click="SubmitBtn_Click"/>
                                <Button x:Name="AttachFileBtn"
                                        Content="📎 Lampirkan File"
                                        FontSize="12" CornerRadius="6" Padding="10,8"
                                        Click="AttachFileBtn_Click"/>
                                <TextBlock x:Name="AttachLabel"
                                           Style="{StaticResource CL_Label}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="SubmitStatusText"
                                       FontSize="11" Margin="0,2"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid><!-- /Right -->
    </Grid>
</Page>
